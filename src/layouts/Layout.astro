---
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sammy Norris",
  description = "A product designer based in London, specialising in creating clear, intuitive, and accessible digital experiences. Skilled across UI and UX design, research, service blueprints, and full product journeys.",
} = Astro.props;

const isHomepage = Astro.url.pathname === "/";
---
<!doctype html>
<html lang="en-GB">
  <head>
 <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        // Dark is the default — only opt out when explicitly set to 'light'.
        if (theme !== 'light') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@200;300;400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL@20,300,0&icon_names=dark_mode,light_mode&display=block"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <ThemeToggle delayed={isHomepage} />
    <slot />
    <script is:inline>
      (function () {
        var original = document.title;
        var timer = null;
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) {
            timer = setTimeout(function () {
              document.title = 'Where did you go?';
            }, 30000);
          } else {
            if (timer) clearTimeout(timer);
            document.title = original;
          }
        });
      })();
    </script>
  </body>
</html>