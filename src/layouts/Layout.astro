---
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sammy Norris — Senior Product Designer",
  description = "Product designer currently living in a regulated world.",
} = Astro.props;
---
<!doctype html>
<html lang="en-GB">
  <head>
 <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@200;300;400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL@20,300,0&icon_names=dark_mode,light_mode&display=block"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <ThemeToggle />
    <slot />
  </body>
</html>