---
import Analytics from "@vercel/analytics/astro";
import BmxBike from "../components/BmxBike.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Sammy Norris",
  description = "A product designer based in London, specialising in creating clear, intuitive, and accessible digital experiences. Skilled across UI and UX design, research, service blueprints, and full product journeys.",
  ogImage = "/social-preview.jpg",
} = Astro.props;

const isHomepage = Astro.url.pathname === "/";
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://www.sammynorris.com").toString();
const ogImageURL = new URL(ogImage, Astro.site ?? "https://www.sammynorris.com").toString();
---
<!doctype html>
<!--

  Do what makes you happy.

  Designed & built by Sammy, Shy & Nova Norris.

-->
<html lang="en-GB">
  <head>
 <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        // Dark is the default — only opt out when explicitly set to 'light'.
        if (theme !== 'light') {
          document.documentElement.classList.add('dark');
        }

        // Refresh should always start at the top of the page.
        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual';
        }
      })();

      // Strip the URL hash after the initial anchor jump so a refresh
      // doesn't re-scroll to a section the visitor only meant to land
      // on once (e.g. arriving via /#work from a project back-button).
      window.addEventListener('load', function() {
        if (window.location.hash) {
          requestAnimationFrame(function() {
            history.replaceState(null, '', window.location.pathname + window.location.search);
          });
        }
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Sammy Norris" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@200;300;400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL@20,300,0&icon_names=dark_mode,light_mode&display=block" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body class="page-enter">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <BmxBike delayed={isHomepage} />
    <ThemeToggle delayed={isHomepage} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <script is:inline>
      (function () {
        var original = document.title;
        var messages = [
          'Where did you go?',
          "I'm still here you know",
          'Okay this is awkward',
          "I'll just be here then...",
          'You forgot about me'
        ];
        var timer = null;
        var interval = null;
        var index = 0;
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) {
            timer = setTimeout(function () {
              document.title = messages[0];
              index = 1;
              interval = setInterval(function () {
                document.title = messages[index];
                index = (index + 1) % messages.length;
              }, 15000);
            }, 15000);
          } else {
            if (timer) clearTimeout(timer);
            if (interval) clearInterval(interval);
            document.title = original;
          }
        });
      })();
    </script>
    <script is:inline>
      // Page transition — intercept internal links and slide out before navigating
      document.addEventListener('click', function (e) {
        var link = e.target.closest('a[href]');
        if (!link || link.target === '_blank') return;
        var href = link.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('http')) return;
        e.preventDefault();
        document.body.style.transition = 'opacity 0.15s ease, transform 0.15s ease';
        document.body.style.opacity = '0';
        document.body.style.transform = 'translateY(-6px)';
        setTimeout(function () { window.location.href = href; }, 160);
      });
    </script>
    <script is:inline>
      (function () {
        if ('ontouchstart' in window) return;
        var dot = document.createElement('div');
        dot.setAttribute('aria-hidden', 'true');
        dot.style.cssText =
          'position:fixed;pointer-events:none;z-index:9999;width:8px;height:8px;' +
          'border-radius:50%;border:0.75px solid #ffffff;background:transparent;' +
          'transform:translate(-50%,-50%);opacity:0;will-change:left,top;';
        document.body.appendChild(dot);
        var mx = 0, my = 0, dx = 0, dy = 0;
        var visible = false;
        var raf;
        function tick() {
          dx += (mx - dx) * 0.08;
          dy += (my - dy) * 0.08;
          dot.style.left = dx + 'px';
          dot.style.top = dy + 'px';
          raf = requestAnimationFrame(tick);
        }
        document.addEventListener('mousemove', function (e) {
          mx = e.clientX;
          my = e.clientY;
          if (!visible) {
            visible = true;
            dx = mx; dy = my;
            dot.style.opacity = '1';
            raf = requestAnimationFrame(tick);
          }
        });
        document.addEventListener('mouseleave', function () {
          visible = false;
          dot.style.opacity = '0';
          if (raf) cancelAnimationFrame(raf);
        });
      })();
    </script>
    <script is:inline>
      document.querySelector('.skip-link').addEventListener('click', function(e) {
        e.preventDefault();
        // On homepage, skip past the hero to the work section
        // On other pages, focus the main content landmark
        // On homepage, focus the first project card
        // On other pages, focus the main content landmark
        var target = document.querySelector('#work .card') || document.getElementById('main-content');
        if (target) target.focus();
      });
    </script>
    <Analytics />
  </body>
</html>