---
import Analytics from "@vercel/analytics/astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title = "Sammy Norris",
  description = "A product designer based in London, specialising in creating clear, intuitive, and accessible digital experiences. Skilled across UI and UX design, research, service blueprints, and full product journeys.",
  ogImage = "/social-preview.jpg",
  ogImageAlt = "Sammy Norris, a product designer based in London",
} = Astro.props;

const isHomepage = Astro.url.pathname === "/";
const siteOrigin = Astro.site ?? "https://www.sammynorris.com";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageURL = new URL(ogImage, siteOrigin).toString();

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Sammy Norris",
  url: new URL("/", siteOrigin).toString(),
  jobTitle: "Senior Product Designer",
  description,
  sameAs: ["https://www.linkedin.com/in/sammy-norris-b0090912a/"],
};
---
<!doctype html>
<!--

  Do what makes you happy.

  Designed & built by Sammy, Shy & Nova Norris.

-->
<html lang="en-GB">
  <head>
 <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        // Dark is the default; only opt out when explicitly set to 'light'.
        if (theme !== 'light') {
          document.documentElement.classList.add('dark');
        }

        // Refresh should always start at the top of the page.
        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual';
        }

        // Direction-aware page entrance: if the previous page exited via a
        // back link, mirror the motion and enter from above. Must run before
        // first paint, hence up here.
        try {
          if (sessionStorage.getItem('sn-nav-dir') === 'back') {
            sessionStorage.removeItem('sn-nav-dir');
            document.documentElement.classList.add('nav-back');
          }
        } catch (e) {}
      })();

      // Strip the URL hash after the initial anchor jump so a refresh
      // doesn't re-scroll to a section the visitor only meant to land
      // on once (e.g. arriving via /#work from a project back-button).
      window.addEventListener('load', function() {
        if (window.location.hash) {
          requestAnimationFrame(function() {
            history.replaceState(null, '', window.location.pathname + window.location.search);
          });
        }
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Sammy Norris" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@200..500&display=swap" rel="stylesheet" />

    <title>{title}</title>

    {isHomepage && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}
  </head>
  <body class="page-enter">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <ThemeToggle delayed={isHomepage} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <script is:inline>
      (function () {
        var original = document.title;
        var timer = null;
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) {
            timer = setTimeout(function () {
              document.title = 'You missed something 👀';
            }, 15000);
          } else {
            if (timer) clearTimeout(timer);
            document.title = original;
          }
        });
      })();
    </script>
    <script is:inline>
      // Page transition: intercept internal links and slide out before
      // navigating. Forward links exit upward; back links (data-nav-back)
      // exit downward and the destination enters from above, so pages leave
      // the way they arrived. Exit accelerates (ease-in) to mirror the
      // decelerating entrance, and is kept short: it is latency on every
      // navigation.
      document.addEventListener('click', function (e) {
        // Leave modified clicks (new tab / window / download) to the browser.
        if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        var link = e.target.closest('a[href]');
        if (!link || link.target === '_blank') return;
        var href = link.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('http')) return;
        e.preventDefault();
        var back = link.hasAttribute('data-nav-back');
        if (back) {
          try { sessionStorage.setItem('sn-nav-dir', 'back'); } catch (err) {}
        }
        document.body.style.transition = 'opacity 0.12s cubic-bezier(0.4, 0, 1, 1), transform 0.12s cubic-bezier(0.4, 0, 1, 1)';
        document.body.style.opacity = '0';
        document.body.style.transform = back ? 'translateY(6px)' : 'translateY(-6px)';
        setTimeout(function () { window.location.href = href; }, 130);
      });
    </script>
    <script is:inline>
      (function () {
        if ('ontouchstart' in window) return;
        var dot = document.createElement('div');
        dot.setAttribute('aria-hidden', 'true');
        dot.style.cssText =
          'position:fixed;pointer-events:none;z-index:9999;width:8px;height:8px;' +
          'border-radius:50%;border:0.75px solid var(--color-primary);background:transparent;' +
          'transform:translate(-50%,-50%);opacity:0;will-change:left,top;';
        document.body.appendChild(dot);
        var mx = 0, my = 0, dx = 0, dy = 0;
        var visible = false;
        var raf;
        function tick() {
          dx += (mx - dx) * 0.08;
          dy += (my - dy) * 0.08;
          dot.style.left = dx + 'px';
          dot.style.top = dy + 'px';
          raf = requestAnimationFrame(tick);
        }
        document.addEventListener('mousemove', function (e) {
          mx = e.clientX;
          my = e.clientY;
          if (!visible) {
            visible = true;
            dx = mx; dy = my;
            dot.style.opacity = '1';
            raf = requestAnimationFrame(tick);
          }
        });
        document.addEventListener('mouseleave', function () {
          visible = false;
          dot.style.opacity = '0';
          if (raf) cancelAnimationFrame(raf);
        });
      })();
    </script>
    <script is:inline>
      document.querySelector('.skip-link').addEventListener('click', function(e) {
        e.preventDefault();
        // Homepage: focus the first project card (past the hero).
        // Other pages: focus the main content landmark.
        var target = document.querySelector('#work .card') || document.getElementById('main-content');
        if (target) target.focus();
      });
    </script>
    <Analytics />
  </body>
</html>