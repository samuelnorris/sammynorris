---
import Layout from "./Layout.astro";
import BackButton from "../components/BackButton.astro";
import Footer from "../components/Footer.astro";
import "../styles/case-study.css";

interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  pageTitle: string;
  meta: MetaItem[];
  description: string;
  signoff: string;          // e.g. "Designed at Close Brothers"
  signoffYear: string;      // e.g. "2025"
  ogImage?: string;
  nextProject?: { title: string; slug: string };
  heroIntro?: boolean;      // opt into the centred title→meta typewriter intro
}

const {
  pageTitle,
  meta,
  description,
  signoff,
  signoffYear,
  ogImage,
  nextProject,
  heroIntro = false,
} = Astro.props;

// The meta types out as a single line — client(s) first, year last,
// e.g. "Close Brothers  ·  2025". Matches the homepage typewriter intro.
const metaYear = meta.find((m) => m.label === "Year")?.value;
const metaText = [
  ...meta.filter((m) => m.label !== "Year").map((m) => m.value),
  metaYear,
]
  .filter(Boolean)
  .join("  ·  ");
// Screen readers get the labelled version, not the char-by-char build.
const metaLabel = meta.map((m) => `${m.label}: ${m.value}`).join(". ");
---

<Layout title={pageTitle} ogImage={ogImage}>

  <!-- Back nav -->
  <nav class="case-nav">
    <BackButton />
  </nav>

  <!-- Hero -->
  <header class:list={["hero", { "hero--intro": heroIntro }]}>
    <div class="hero__lead">
      <h1 class="hero__title" data-reveal={heroIntro ? undefined : ""} style={heroIntro ? undefined : "--delay: 0.06s"}>
        <slot name="title" />
      </h1>

      <p class="hero__meta" data-reveal={heroIntro ? undefined : ""} style={heroIntro ? undefined : "--delay: 0.22s"} data-meta={metaText}>
        <span class="hero__meta-line b1" aria-hidden="true">{metaText}</span>
        <span class="hero__meta-sr">{metaLabel}</span>
      </p>
    </div>

    <p class="hero__desc b1" data-reveal={heroIntro ? undefined : ""} style={heroIntro ? undefined : "--delay: 0.3s"}>
      {description}
    </p>
  </header>

  {heroIntro && (
    <!-- Hero intro (commission): centred title+meta typewriter, then slide up.
         Inline so it runs during parse and sets the centred state before first
         paint. Plain JS (no TS) as it ships to the browser verbatim. -->
    <script is:inline>
      (function () {
        var hero = document.querySelector(".hero--intro");
        if (!hero) return;

        var lead = hero.querySelector(".hero__lead");
        var titleEl = hero.querySelector(".hero__title");
        var metaEl = hero.querySelector(".hero__meta");
        var metaLine = metaEl && metaEl.querySelector(".hero__meta-line");
        var descEl = hero.querySelector(".hero__desc");
        if (!lead || !titleEl || !metaEl || !metaLine || !descEl) return;

        var reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var key = "sn-hero-intro:" + window.location.pathname;
        var played = false;
        try { played = !!sessionStorage.getItem(key); } catch (e) {}
        var viaAnchor = !!window.location.hash;

        // Skip: leave the hero in its natural, fully-visible state.
        if (reduced || played || viaAnchor) return;
        try { sessionStorage.setItem(key, "1"); } catch (e) {}

        // Enter the centred, full-height state before first paint: the title
        // centres, meta + desc stay hidden, and the body sits below the fold.
        hero.classList.add("is-tall", "is-centred");
        window.scrollTo(0, 0);

        // Capture the title's characters and which are emphasised, so it can be
        // rebuilt char by char while keeping the <em> on the last word. Template
        // indentation around the slot lands in the text nodes, so collapse
        // whitespace runs to single spaces and trim the ends first.
        var raw = [];
        Array.prototype.forEach.call(titleEl.childNodes, function (node) {
          var em = node.nodeType === 1 && node.tagName === "EM";
          var text = node.textContent || "";
          for (var i = 0; i < text.length; i++) raw.push({ ch: text[i], em: em });
        });
        var chars = [];
        var prevSpace = true;
        for (var r = 0; r < raw.length; r++) {
          if (/\s/.test(raw[r].ch)) {
            if (prevSpace) continue;
            chars.push({ ch: " ", em: false });
            prevSpace = true;
          } else {
            chars.push({ ch: raw[r].ch, em: raw[r].em });
            prevSpace = false;
          }
        }
        while (chars.length && chars[chars.length - 1].ch === " ") chars.pop();
        // Only the title types out. The meta line stays hidden and fades in
        // with the description once the slide finishes.
        titleEl.textContent = "";

        var TITLE_SPEED = 85;
        var START_DELAY = 450;
        var TITLE_HOLD = 500;

        var openEm = null, openText = null;
        function putChar(c) {
          if (c.em) {
            if (!openEm) { openEm = document.createElement("em"); titleEl.appendChild(openEm); openText = null; }
            openEm.textContent += c.ch;
          } else {
            if (!openText) { openText = document.createTextNode(""); titleEl.appendChild(openText); openEm = null; }
            openText.textContent += c.ch;
          }
        }

        function typeTitle(i) {
          if (i < chars.length) {
            putChar(chars[i]);
            setTimeout(function () { typeTitle(i + 1); }, TITLE_SPEED);
          } else {
            titleEl.classList.remove("is-typing");
            titleEl.classList.add("is-done");
            setTimeout(slideUp, TITLE_HOLD);
          }
        }

        // The site-wide spring curve — every phase of the intro shares it.
        // Resolved from the CSS token so it stays in step with global.css.
        var CURVE = "var(--ease-spring)";

        function slideUp() {
          // FLIP the title from centred to the top of the still-full-height hero.
          // The body stays below the fold (.is-tall) so no images reveal yet.
          var first = lead.getBoundingClientRect().top;
          hero.classList.remove("is-centred");
          var last = lead.getBoundingClientRect().top;
          var delta = first - last;

          lead.style.transition = "none";
          lead.style.transform = "translateY(" + delta + "px)";

          // Prime the meta and description to drift in with a small rise while
          // the slide is still decelerating — overlapped and staggered, not
          // queued behind it.
          metaEl.style.opacity = "0";
          metaEl.style.transform = "translateY(12px)";
          descEl.style.opacity = "0";
          descEl.style.transform = "translateY(12px)";

          // Commit the inverted start position before animating.
          void lead.offsetHeight;

          lead.style.transition = "transform 0.9s " + CURVE;
          lead.style.transform = "translateY(0)";

          metaEl.style.transition = "opacity 0.8s ease 0.45s, transform 0.8s " + CURVE + " 0.45s";
          metaEl.style.opacity = "1";
          metaEl.style.transform = "translateY(0)";
          descEl.style.transition = "opacity 0.8s ease 0.6s, transform 0.8s " + CURVE + " 0.6s";
          descEl.style.opacity = "1";
          descEl.style.transform = "translateY(0)";

          lead.addEventListener("transitionend", function onEnd(e) {
            if (e.propertyName !== "transform") return;
            lead.removeEventListener("transitionend", onEnd);
            lead.style.transition = "";
            lead.style.transform = "";
          });

          // Start releasing the body while the description is still settling,
          // so the phases chain into one continuous motion.
          setTimeout(revealBody, 1150);
        }

        function revealBody() {
          // min-height: auto cannot be transitioned, so FLIP the collapse as an
          // eased height animation: the body glides up and Figure 01 soft-reveals
          // via the scroll observer as it enters, instead of jumping in.
          var startH = hero.offsetHeight;
          hero.classList.remove("is-tall");
          var endH = hero.offsetHeight;
          if (endH >= startH) return;

          hero.style.height = startH + "px";
          void hero.offsetHeight;
          hero.style.transition = "height 1.1s " + CURVE;
          hero.style.height = endH + "px";

          hero.addEventListener("transitionend", function onEnd(e) {
            if (e.propertyName !== "height") return;
            hero.removeEventListener("transitionend", onEnd);
            hero.style.transition = "";
            hero.style.height = "";
          });
        }

        titleEl.classList.add("is-typing");
        setTimeout(function () { typeTitle(0); }, START_DELAY);
      })();
    </script>
  )}

  <!-- Page body: figures, chapters, stats -->
  <slot />

  <!-- Closing -->
  <section class="closing" data-reveal>
    <p class="closing__signoff">
      <em>{signoff}</em>, {signoffYear}.
    </p>
    <div class="closing__actions">
      <a href="/#work" class="closing__cta" aria-label="Return to all work">
        <span class="closing__cta-icon">
          <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M5 12l7 7M5 12l7-7" />
          </svg>
        </span>
        <span class="closing__cta-label">Return to all work</span>
      </a>
      {nextProject && (
        <a href={`/${nextProject.slug}`} class="closing__cta closing__cta--next" aria-label={`Next project: ${nextProject.title}`}>
          <span class="closing__cta-label">Next: {nextProject.title}</span>
          <span class="closing__cta-icon">
            <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M14 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      )}
    </div>
  </section>

  <Footer />

</Layout>

<script>
  import "../scripts/reveal.ts";

  // Type the hero meta line in — plays once per case study per session,
  // mirroring the homepage name intro. Repeat views and reduced-motion
  // users get it instantly.
  (function () {
    // The intro-enabled case study (commission) types its meta as part of the
    // centred title→meta→slide sequence, so skip the standalone typewriter there.
    if (document.querySelector('.hero--intro')) return;
    const metaMaybe = document.querySelector<HTMLElement>('.hero__meta');
    const lineMaybe = metaMaybe?.querySelector<HTMLElement>('.hero__meta-line');
    if (!metaMaybe || !lineMaybe) return;
    // Narrowed re-bindings so the types hold inside step() below.
    const meta = metaMaybe;
    const line = lineMaybe;

    const full = meta.getAttribute('data-meta') || line.textContent || '';
    const key = 'sn-meta-typed:' + window.location.pathname;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Repeat views / reduced-motion: leave the server-rendered line in place.
    if (sessionStorage.getItem(key) || reduced) return;
    sessionStorage.setItem(key, '1');

    line.textContent = '';
    meta.classList.add('is-typing');

    const typeSpeed = 55;
    const startDelay = 450;
    let i = 0;

    function step() {
      if (i <= full.length) {
        line.textContent = full.slice(0, i);
        i += 1;
        setTimeout(step, typeSpeed);
      } else {
        meta.classList.remove('is-typing');
        meta.classList.add('is-done');
      }
    }
    setTimeout(step, startDelay);
  })();

  // Hide the fixed top nav when the bottom CTA is visible
  const nav = document.querySelector<HTMLElement>('.case-nav');
  const bottomCta = document.querySelector<HTMLElement>('.closing__cta');
  if (nav && bottomCta) {
    const navObserver = new IntersectionObserver(
      (entries) => {
        nav.style.opacity = entries[0].isIntersecting ? '0' : '';
        nav.style.pointerEvents = entries[0].isIntersecting ? 'none' : '';
      },
      { threshold: 0 }
    );
    navObserver.observe(bottomCta);
  }
</script>
