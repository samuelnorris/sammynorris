---
interface Props {
  delayed?: boolean;
}
const { delayed = false } = Astro.props;
---

<button
  class:list={["theme-toggle", { "theme-toggle--delayed": delayed }]}
  id="themeToggle"
  aria-label="Toggle dark mode"
>
  <span class="theme-toggle__label theme-toggle__label--light">Light</span>
  <span class="theme-toggle__label theme-toggle__label--dark">Dark</span>
  <svg class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
  </svg>
  <svg class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style>
  .theme-toggle {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-tertiary);
    border-radius: 99px;
    color: var(--color-primary);
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.3s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
  }

  .theme-toggle--delayed {
    opacity: 0;
    animation: toggleFadeIn 1.2s ease 5.3s forwards;
  }

  .theme-toggle__icon {
    display: block;
  }

  .theme-toggle__label {
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.4;
    padding-right: 12px;
  }

  /* Light mode: show "Dark" label + moon icon */
  .theme-toggle__icon--sun,
  .theme-toggle__label--light {
    display: none;
  }

  /* Dark mode: show "Light" label + sun icon */
  :global(.dark) .theme-toggle__icon--sun,
  :global(.dark) .theme-toggle__label--light {
    display: flex;
  }
  :global(.dark) .theme-toggle__icon--moon,
  :global(.dark) .theme-toggle__label--dark {
    display: none;
  }

  @keyframes toggleFadeIn {
    to { opacity: 1; }
  }
</style>

<script>
  const toggle = document.getElementById('themeToggle');
  const html = document.documentElement;

  toggle?.setAttribute('aria-pressed', String(html.classList.contains('dark')));

  toggle?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    toggle.setAttribute('aria-pressed', String(isDark));
  });
</script>