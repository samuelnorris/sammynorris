---
interface Props {
  delayed?: boolean;
}
const { delayed = false } = Astro.props;
---

<button
  class:list={["theme-toggle", { "theme-toggle--delayed": delayed }]}
  id="themeToggle"
  aria-label="Toggle dark mode"
>
  <span class="theme-toggle__label theme-toggle__label--light">Light</span>
  <span class="theme-toggle__label theme-toggle__label--dark">Dark</span>
  <span class="theme-toggle__icon theme-toggle__icon--sun material-symbols-rounded">light_mode</span>
  <span class="theme-toggle__icon theme-toggle__icon--moon material-symbols-rounded">dark_mode</span>
</button>

<style>
  .theme-toggle {
    position: fixed;
    top: 24px;
    right: 24px;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-tertiary);
    border-radius: 99px;
    color: var(--color-primary);
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.3s ease;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
  }

  .theme-toggle--delayed {
    opacity: 0;
    animation: toggleFadeIn 1.2s ease 5.3s forwards;
  }

  .material-symbols-rounded {
    font-family: 'Material Symbols Rounded';
    font-size: 20px;
    line-height: 1;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'opsz' 20;
  }

  .theme-toggle__label {
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.4;
    padding-right: 12px;
  }

  /* Light mode: show "Dark" label + moon icon */
  .theme-toggle__icon--sun,
  .theme-toggle__label--light {
    display: none;
  }

  /* Dark mode: show "Light" label + sun icon */
  :global(.dark) .theme-toggle__icon--sun,
  :global(.dark) .theme-toggle__label--light {
    display: flex;
  }
  :global(.dark) .theme-toggle__icon--moon,
  :global(.dark) .theme-toggle__label--dark {
    display: none;
  }

  @keyframes toggleFadeIn {
    to { opacity: 1; }
  }
</style>

<script>
  const toggle = document.getElementById('themeToggle');
  const html = document.documentElement;

  toggle?.setAttribute('aria-pressed', String(html.classList.contains('dark')));

  toggle?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    toggle.setAttribute('aria-pressed', String(isDark));
  });
</script>