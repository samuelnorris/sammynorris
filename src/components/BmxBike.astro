---
interface Props {
  delayed?: boolean;
}
const { delayed = false } = Astro.props;
---

<svg
  class:list={["bmx-bike", { "bmx-bike--delayed": delayed }]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="18 74 380 268"
  role="img"
  aria-label="BMX bike with spinning wheels and cranks"
>
  <style is:inline>
    .bmx-spin, .bmx-crank, .bmx-pedal {
      transform-box: fill-box;
      transform-origin: center;
    }
    /* 10s riding loop:
       0-3s    slow pedalling (carried in from loop restart, wheels never stop)
       3-5.5s  fast pedalling
       5.5-8.8s coasting, wheels gradually slowing
       8.8-10s pedalling resumes while still rolling */
    .bmx-spin  { animation: bmx-wheels 10s linear infinite; }
    .bmx-crank { animation: bmx-cranks 10s linear infinite; }
    .bmx-pedal { animation: bmx-pedals 10s linear infinite; }
    .bmx-spokes { animation: bmx-spokesfade 10s infinite; }
    .bmx-blur   { opacity: 0; animation: bmx-blurfade 10s infinite; }

    /* wheels: geared 2.5x to cranks while pedalling; coast decelerates
       but stays rolling into the restart (10.5 total turns = seamless
       on a 36-spoke wheel) */
    @keyframes bmx-wheels {
      0%   { transform: rotate(0turn);      animation-timing-function: linear; }
      30%  { transform: rotate(1.875turn);  animation-timing-function: ease-in; }
      55%  { transform: rotate(6.5turn);    animation-timing-function: ease-out; }
      88%  { transform: rotate(9.85turn);   animation-timing-function: linear; }
      100% { transform: rotate(10.5turn); }
    }
    /* cranks: steady, wind up, ease to a stop, hold, then re-engage
       before the wheels run down */
    @keyframes bmx-cranks {
      0%   { transform: rotate(0turn);     animation-timing-function: linear; }
      30%  { transform: rotate(0.75turn);  animation-timing-function: ease-in; }
      55%  { transform: rotate(2.6turn);   animation-timing-function: ease-out; }
      64%  { transform: rotate(2.85turn); }
      88%  { transform: rotate(2.85turn);  animation-timing-function: ease-in; }
      100% { transform: rotate(3turn); }
    }
    /* pedals: exact mirror of cranks so they stay level throughout */
    @keyframes bmx-pedals {
      0%   { transform: rotate(0turn);      animation-timing-function: linear; }
      30%  { transform: rotate(-0.75turn);  animation-timing-function: ease-in; }
      55%  { transform: rotate(-2.6turn);   animation-timing-function: ease-out; }
      64%  { transform: rotate(-2.85turn); }
      88%  { transform: rotate(-2.85turn);  animation-timing-function: ease-in; }
      100% { transform: rotate(-3turn); }
    }
    /* crossfade re-synced: spokes readable through the slow roll and
       restart, blur through the sprint and early coast */
    @keyframes bmx-spokesfade {
      0%, 20%   { opacity: 1; }
      30%, 78%  { opacity: 0; }
      90%, 100% { opacity: 1; }
    }
    @keyframes bmx-blurfade {
      0%, 20%   { opacity: 0; }
      30%, 78%  { opacity: 0.32; }
      90%, 100% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .bmx-spin, .bmx-crank, .bmx-pedal, .bmx-spokes, .bmx-blur { animation: none; }
    }
  </style>

