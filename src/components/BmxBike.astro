  <!-- Cranks: two arms 180 degrees apart, pedals counter-rotate to stay level -->
  <g class="bmx-crank">
    <g stroke="currentColor" stroke-width="9" stroke-linecap="round">
      <line x1="181.0" y1="257.0" x2="196.5" y2="302.0"/>
      <line x1="181.0" y1="257.0" x2="165.5" y2="212.0"/>
    </g>
    <rect class="bmx-pedal" x="182.5" y="298.0" width="28" height="8" rx="3" fill="currentColor"/>
    <rect class="bmx-pedal" x="151.5" y="208.0" width="28" height="8" rx="3" fill="currentColor"/>
  </g>
</svg>

<style>
  .bmx-bike {
    display: block;
    height: 50px;
    width: auto;
    color: var(--color-primary);
    transition: color 0.3s ease;
  }

  .bmx-bike--delayed {
    opacity: 0;
    animation: bmxFadeIn 1.2s ease 5.3s forwards;
  }

  @keyframes bmxFadeIn {
    to { opacity: 1; }
  }
</style>
