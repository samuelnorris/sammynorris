    </g>
    <circle cx="94" cy="267" r="7" fill="currentColor"/>
  </g>
  <circle class="bmx-blur" cx="94" cy="267" r="32.2" fill="none" stroke="currentColor" stroke-width="46.3"/>
  <!-- Front wheel spokes -->
  <g class="bmx-spin">
    <g class="bmx-spokes" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
