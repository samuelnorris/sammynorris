<style>
  .bmx-bike {
    position: fixed;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    height: 42px;
    width: auto;
    color: var(--color-primary);
    transition: color 0.3s ease;
  }

  .bmx-bike--delayed {
    opacity: 0;
    animation: bmxFadeIn 1.2s ease 5.3s forwards;
  }

  @keyframes bmxFadeIn {
    to { opacity: 1; }
  }
</style>
