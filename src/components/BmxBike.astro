  <!-- In-wheel tube segments (rebuilt as vectors) -->
  <g stroke="currentColor" stroke-linecap="round" fill="none">
    <line x1="321" y1="267" x2="295" y2="191" stroke-width="9.5"/>   <!-- fork -->
    <line x1="94" y1="267" x2="155" y2="217.4" stroke-width="9"/>    <!-- seat stay -->
    <line x1="94" y1="267" x2="181" y2="257" stroke-width="9"/>      <!-- chainstay -->
  </g>
  <!-- Perfect tyre rings overlaid to clean up traced edges -->
  <circle cx="94" cy="267" r="61.4" fill="none" stroke="currentColor" stroke-width="12.2"/>
  <circle cx="321" cy="267" r="61.4" fill="none" stroke="currentColor" stroke-width="12.2"/>
  <!-- Perfect sprocket disc -->
