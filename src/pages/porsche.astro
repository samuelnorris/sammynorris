---
import CaseStudyLayout from "../layouts/CaseStudyLayout.astro";

const meta = [
  { label: "Year", value: "2021" },
  { label: "Client", value: "Porsche" },
  { label: "Role", value: "Senior Product Designer" },
  { label: "Agency", value: "Brandwidth" },
];

const stats = [
  { value: "watchOS", label: "Native build" },
  { value: "1", label: "Lead designer" },
  { value: "4", label: "Vital stats" },
  { value: "Live", label: "Telemetry" },
];
---

<CaseStudyLayout
  pageTitle="Porsche - Sammy Norris"
  meta={meta}
  description="A native Apple Watch app giving Porsche owners instant, glanceable access to their car's key stats - designed from IA to handoff at Brandwidth."
  signoff="Designed at Brandwidth"
  signoffYear="2021"
  nextProject={{ title: "Toyota", slug: "toyota" }}
>
  <Fragment slot="title">Porsche</Fragment>

  <!-- Figure 01 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/porsche/image-porsche-1-m.jpg" />
      <img src="/images/projects/porsche/image-porsche-1.jpg" alt="Porsche Apple Watch app hero" loading="eager" />
    </picture>
  </figure>

  <!-- Chapter I - Challenge -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num" aria-hidden="true">I.</span>
      <h2 class="chapter__label b2">The ask</h2>
    </header>

    <div class="chapter__body chapter__body--double">
      <p class="b1">
        Porsche wanted to deepen the connection between owners and their cars. The brief was to give drivers charging status, mileage, fuel levels, and lock status directly on their wrist - without picking up their phone.
      </p>
      <p class="b1">
        The result had to feel like Porsche: precise, considered, and premium. Not generic utility software.
      </p>
    </div>
  </section>

  <!-- Figure 02 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/porsche/image-porsche-2-m.jpg" />
      <img src="/images/projects/porsche/image-porsche-2.jpg" alt="Apple Watch interface screens" loading="lazy" />
    </picture>
  </figure>

  <!-- Chapter II - Process -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num" aria-hidden="true">II.</span>
      <h2 class="chapter__label b2">The process</h2>
    </header>

    <h3 class="chapter__h2">
      Research first, <em>pixels second.</em>
    </h3>

    <div class="chapter__body chapter__body--double">
      <p class="b1">
        I was the primary designer on the project at Brandwidth, taking it from initial concept through to final handoff. I worked within two significant constraints: watchOS design limitations and the technical restrictions of the connected car platform, which governed how and when live vehicle data could be surfaced.
      </p>
      <p class="b1">
        I started with IA and user flows - mapping what information owners actually wanted at a glance versus what belonged deeper in the app. I spoke with Porsche owners to validate that hierarchy before touching screen design. From there I produced low and high fidelity designs, iterated on edge cases around connectivity states, and presented work directly to Porsche stakeholders alongside Brandwidth account managers.
      </p>
    </div>
  </section>

  <!-- Figure 03 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/porsche/image-porsche-3-m.jpg" />
      <img src="/images/projects/porsche/image-porsche-3.jpg" alt="Live telemetry on watchOS" loading="lazy" />
    </picture>
  </figure>

  <!-- Chapter III - Outcome -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num" aria-hidden="true">III.</span>
      <h2 class="chapter__label b2">The outcome</h2>
    </header>

    <h3 class="chapter__h2">
      Now part of <em>Porsche Connect.</em>
    </h3>

    <div class="stats">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat__value">{s.value}</span>
          <span class="stat__label b3">{s.label}</span>
        </div>
      ))}
    </div>

    <div class="chapter__body">
      <p class="b1">
        The app shipped as part of what is now known as Porsche Connect.
      </p>
    </div>
  </section>

  <!-- Figure 04 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/porsche/image-porsche-4-m.jpg" />
      <img src="/images/projects/porsche/image-porsche-4.jpg" alt="Watch face detail" loading="lazy" />
    </picture>
  </figure>

  <!-- Figure 05 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/porsche/image-porsche-5-m.jpg" />
      <img src="/images/projects/porsche/image-porsche-5.jpg" alt="Porsche Connect on Apple Watch" loading="lazy" />
    </picture>
  </figure>

  <!-- Figure 06 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/porsche/image-porsche-6-m.jpg" />
      <img src="/images/projects/porsche/image-porsche-6.jpg" alt="Porsche Apple Watch detail" loading="lazy" />
    </picture>
  </figure>
</CaseStudyLayout>
