---
import BmxBike from "../components/BmxBike.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";

// Read times: word count ÷ 238 wpm (average adult reading speed), rounded up.
const projects = [
  { title: "Commission", year: "2025", slug: "commission", read: "2 min read" },
  { title: "Ekeg+", year: "2023", slug: "ekeg", read: "2 min read" },
  { title: "Gener8", year: "2021", slug: "gener8", read: "1 min read" },
  { title: "Larkbury", year: "2022", slug: "larkbury", read: "1 min read" },
  { title: "Porsche", year: "2021", slug: "porsche", read: "1 min read" },
  { title: "Toyota", year: "2020", slug: "toyota", read: "1 min read" },
];

---

<Layout>

  <!-- Hero -->
  <header class="hero">
    <div class="hero__content">
      <BmxBike delayed />
      <h1 class="hero__name h1" id="typewriter" aria-label="Sammy Norris">Sammy Norris</h1>
      <p class="hero__tagline">Product <span style="color: var(--color-secondary);">designer</span> currently living in a regulated world.</p>
    </div>
  </header>

  <!-- Work -->
  <section class="work" id="work">
    <h2 class="section-label" data-reveal>Selected work</h2>
    <div class="work__grid">
      {projects.map((project, i) => (
        <a
          href={`/${project.slug}`}
          class="card"
          data-reveal
          data-cursor-label={project.read}
          style={`--delay: ${i * 0.08}s`}
        >
          <div class="card__image">
            <picture>
              <source media="(max-width: 768px)" type="image/webp" srcset={`/images/projects/${project.slug}-mobile.webp`} width="1125" height="1500" />
              <source media="(max-width: 768px)" srcset={`/images/projects/${project.slug}-mobile.png`} width="1125" height="1500" />
              <source type="image/webp" srcset={`/images/projects/${project.slug}-desktop.webp`} width="2000" height="1500" />
              <img
                src={`/images/projects/${project.slug}-desktop.png`}
                alt=""
                loading="lazy"
                width="2000"
                height="1500"
              />
            </picture>
          </div>
          <div class="card__info">
            <span class="card__title b2">{project.title}</span>
            <span class="card__year b3">{project.year}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="about__inner" data-reveal>
      <blockquote class="about__quote">
        Crafting clarity from complexity in regulated environments.
      </blockquote>
      <div class="about__body">
        <p class="b1">
          Senior Product Designer with experience delivering complex digital
          products across automotive and financial services. I focus on the full
          product lifecycle - from discovery and service design through to
          delivery - collaborating with engineering, legal, and compliance teams.
        </p>
        <a href="/about" class="about__cta" aria-label="More about me">
          <span class="about__cta-label">More about me</span>
          <span class="about__cta-icon">
            <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="home-cta">
    <div class="footer__cta" data-reveal>
      <h2 class="footer__heading">Let&rsquo;s work together.</h2>
      <a href="mailto:hello@sammynorris.com" class="footer__email">hello@sammynorris.com</a>
    </div>
  </section>

  <!-- Custom cursor bubble: types a project's reading time on hover. The outer
       element is positioned to the pointer; the inner element owns the
       pop-in entrance animation. -->
  <div class="cursor-bubble" aria-hidden="true">
    <div class="cursor-bubble__inner">
      <span class="cursor-bubble__text"></span>
      <svg class="cursor-bubble__tail" viewBox="0 0 18 18" width="18" height="18" aria-hidden="true" focusable="false">
        <path d="M18 1 C 18 11 13.5 17 6.5 17 C 4.8 17 4.2 15.8 5.2 14.3 C 7 11.5 10 12.8 12.5 11 C 14.6 9.4 16 5.6 18 6 Z" />
      </svg>
    </div>
  </div>

  <Footer />

</Layout>

<script>
  import "../scripts/reveal.ts";

  (function () {
    const el = document.getElementById("typewriter");
    if (!el) return;

    // Skip animation if already played this session, arriving via anchor,
    // or if the user prefers reduced motion.
    const alreadyPlayed = sessionStorage.getItem('sn-intro-played');
    const arrivingViaAnchor = !!window.location.hash;
    if (alreadyPlayed || arrivingViaAnchor || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      el.textContent = "Sammy Norris";
      el.classList.add("typewriter--done");
      document.getElementById("themeToggle")?.classList.remove("theme-toggle--delayed");
      document.querySelector(".bmx-bike")?.classList.remove("bmx-bike--delayed");
      var tagline = document.querySelector('.hero__tagline');
      if (tagline) {
        tagline.style.animation = 'none';
        tagline.style.opacity = '1';
        tagline.style.maxHeight = '4em';
        tagline.style.marginTop = '24px';
      }
      return;
    }
    sessionStorage.setItem('sn-intro-played', '1');

    // Clear the server-rendered name so the typewriter builds it from empty.
    el.textContent = "";

    const typeSpeed = 200;
    const deleteSpeed = 100;
    const startDelay = 600;
    const pauseBeforeDelete = 800;
    const pauseBeforeRetype = 400;

    el.classList.add("typewriter--typing");

    function typeText(text, i, cb) {
      if (i < text.length) {
        el.textContent += text[i];
        setTimeout(function () { typeText(text, i + 1, cb); }, typeSpeed);
      } else if (cb) {
        cb();
      }
    }

    function deleteChars(count, cb) {
      var current = el.textContent || "";
      if (count > 0 && current.length > 0) {
        el.textContent = current.slice(0, -1);
        setTimeout(function () { deleteChars(count - 1, cb); }, deleteSpeed);
      } else if (cb) {
        cb();
      }
    }

    setTimeout(function () {
      typeText("Samuel", 0, function () {
        setTimeout(function () {
          deleteChars(3, function () {
            setTimeout(function () {
              typeText("my Norris", 0, function () {
                el.classList.remove("typewriter--typing");
                el.classList.add("typewriter--done");
              });
            }, pauseBeforeRetype);
          });
        }, pauseBeforeDelete);
      });
    }, startDelay);
  })();

</script>

<script>
  // Custom cursor bubble: on hover over a project card, types out that card's
  // reading time as an iMessage-style bubble (brand colours), holds, deletes,
  // then returns the native cursor. One shared bubble across all cards.
  (function () {
    const cards = document.querySelectorAll("[data-cursor-label]");
    const bubble = document.querySelector(".cursor-bubble");
    if (!cards.length || !bubble) return;

    // Pointer-only affordance — skip on touch / coarse pointers.
    if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;

    // Disable entirely when the user prefers reduced motion — no bubble at all.
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    // <body> keeps an identity transform from its page-enter animation, which
    // makes it (not the viewport) the containing block for any position:fixed
    // descendant — offsetting this bubble by the scroll position. Re-parent it
    // to <html> so it stays a true viewport-fixed element at any scroll depth.
    document.documentElement.appendChild(bubble);

    const textEl = bubble.querySelector(".cursor-bubble__text");

    const TYPE_MS = 50; // per character while typing out
    const DELETE_MS = 45; // per character while deleting
    const HOLD_MS = 1750; // pause once fully typed

    let timers = [];
    let activeCard = null;
    let label = "";
    function clearTimers() {
      timers.forEach(clearTimeout);
      timers = [];
    }
    function after(ms, fn) {
      timers.push(setTimeout(fn, ms));
    }

    function move(e) {
      bubble.style.transform =
        "translate(" + e.clientX + "px, " + e.clientY + "px) translate(8px, -100%)";
    }

    function hide() {
      // Cycle finished (or pointer left): clear the bubble and bring the native
      // cursor back over the card.
      clearTimers();
      if (activeCard) activeCard.classList.remove("card--bubbling");
      activeCard = null;
      bubble.classList.remove("cursor-bubble--visible");
      textEl.textContent = "";
    }

    function typeOut(i) {
      if (i > label.length) { after(HOLD_MS, function () { deleteBack(label.length - 1); }); return; }
      textEl.textContent = label.slice(0, i);
      after(TYPE_MS, function () { typeOut(i + 1); });
    }
    function deleteBack(i) {
      if (i < 0) { hide(); return; }
      textEl.textContent = label.slice(0, i);
      after(DELETE_MS, function () { deleteBack(i - 1); });
    }

    cards.forEach(function (card) {
      card.addEventListener("mouseenter", function (e) {
        clearTimers();
        if (activeCard && activeCard !== card) activeCard.classList.remove("card--bubbling");
        activeCard = card;
        label = card.getAttribute("data-cursor-label") || "";
        move(e);
        timers.push(setTimeout(function () {
          if (activeCard !== card) return;
          // Hide the native cursor (the bubble becomes the cursor) while animating.
          card.classList.add("card--bubbling");
          bubble.classList.add("cursor-bubble--visible");
          textEl.textContent = "";
          typeOut(0);
        }, 250));
      });
      card.addEventListener("mousemove", move);
      card.addEventListener("mouseleave", function () {
        if (activeCard === card) hide();
      });
    });
  })();
</script>

<style>
  /* ===================== Hero ===================== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    overflow: hidden;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero__content > :global(.bmx-bike) {
    margin-bottom: 32px;
  }

  .hero__name {
    white-space: nowrap;
    line-height: 0.85;
    padding-bottom: 0.15em;
  }

  .hero__name::after {
    content: "";
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: var(--color-primary);
    margin-left: 4px;
    vertical-align: baseline;
    animation: blink 1s ease-in-out infinite;
  }

  .hero__name.typewriter--done::after {
    animation: fadeOut 1.2s ease forwards;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @keyframes fadeOut {
    to { opacity: 0; }
  }

  .hero__tagline {
    font-family: var(--font-sans);
    font-size: var(--text-b2);
    font-weight: 300;
    letter-spacing: -0.01em;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    margin-top: 0;
    animation: taglineIn 1.2s ease 5.3s forwards;
  }

  @keyframes taglineIn {
    to {
      opacity: 1;
      max-height: 4em;
      margin-top: 24px;
    }
  }

  /* ===================== Work ===================== */
  .work {
    padding: var(--space-act) 24px var(--space-rhythm);
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 1818px;
    box-sizing: border-box;
    width: 100%;
  }

  .section-label {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .work__grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .card {
    grid-column: span 6;
    text-decoration: none;
    color: var(--color-primary);
    background: var(--color-card-bg);
    border-radius: 12px;
    padding: 8px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card:hover {
    transform: translateY(-4px);
  }

  /* Keyboard focus: snap the card fully visible with a clear ring straight away.
     The scroll-reveal starts cards at opacity:0, so without this the focus ring
     is painted on an invisible card and keyboard users cannot track focus. */
  .card:focus-visible {
    opacity: 1;
    transform: translateY(-4px);
    outline: 3px solid var(--color-secondary);
    outline-offset: 3px;
    transition: none;
  }

  .card__image {
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-card-image-bg);
  }

  .card__image img {
    display: block;
    width: 100%;
    height: unset;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card:hover .card__image img {
    transform: scale(1.03);
  }

  .card__info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 4px 4px;
  }

  .card__year {
    color: var(--color-secondary);
  }

  /* ===================== Cursor reading-time bubble ===================== */
  /* Hide the native cursor only while the bubble is animating, so the bubble
     reads as the cursor. Once the type/delete cycle finishes the class is
     removed and the native cursor returns. Gated to fine pointers (touch
     unaffected). */
  @media (hover: hover) and (pointer: fine) {
    .card--bubbling {
      cursor: none;
    }
  }

  .cursor-bubble {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9998;
    pointer-events: none;
    transform: translate(-200px, -200px);
    will-change: transform;
  }

  /* Appearance lives on the inner element so the outer stays free for the
     pointer-following transform. Hidden by default; pops in once
     .cursor-bubble--visible is added. */
  .cursor-bubble__inner {
    position: relative;
    display: inline-block;
    opacity: 0;
    transform-origin: bottom left;
  }

  .cursor-bubble--visible .cursor-bubble__inner {
    animation: snPopIn 0.3s ease-out forwards;
  }

  @keyframes snPopIn {
    0%   { opacity: 0; transform: scale(0); }
    70%  { opacity: 1; transform: scale(1.12); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* iMessage-style bubble in our colours (not Apple blue). Text uses the page
     background colour so it stays legible on the accent in both themes. */
  .cursor-bubble__text {
    position: relative;
    z-index: 1;
    display: inline-block;
    background: var(--color-secondary);
    color: var(--color-bg);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1;
    white-space: nowrap;
    padding: 9px 14px;
    border-radius: 18px;
    /* Square off the tail corner so the bubble body flows into the tail. */
    border-bottom-left-radius: 7px;
  }

  /* The tail: an SVG so the concave iOS "hook" stays transparent and reads
     correctly over the card image (a CSS mask-tail would need a solid bg).
     Sits behind the bubble body so its top edge tucks under the rounded corner. */
  .cursor-bubble__tail {
    position: absolute;
    bottom: 0;
    left: -7px;
    z-index: 0;
    display: block;
    fill: var(--color-secondary);
    pointer-events: none;
  }

  /* ===================== About ===================== */
  .about {
    padding: var(--space-act) 24px;
    max-width: 1818px;
    box-sizing: border-box;
    width: 100%;
  }

  .about__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .about__quote {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .about__body {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-top: 8px;
  }

  .about__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 4px 4px 16px;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-tertiary);
    border-radius: 99px;
    text-decoration: none;
    color: var(--color-primary);
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.3s ease;
    width: fit-content;
  }

  .about__cta:hover {
    border-color: var(--color-primary);
  }

  .about__cta-label {
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }

  .about__cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 100px;
    background-color: var(--color-card-image-bg);
    flex-shrink: 0;
  }

  /* ===================== Closing CTA ===================== */
  .home-cta {
    padding: var(--space-act) 24px 0;
    max-width: 1818px;
    box-sizing: border-box;
    width: 100%;
  }

  .footer__cta {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer__heading {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    font-weight: 400;
    white-space: nowrap;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .footer__email {
    font-family: var(--font-sans);
    font-size: var(--text-b1);
    font-weight: 300;
    color: var(--color-secondary);
    text-decoration: none;
    width: fit-content;
    transition: opacity 0.2s ease;
  }

  .footer__email:hover {
    opacity: 0.6;
  }

  /* ===================== Scroll reveal ===================== */
  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0s),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0s);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===================== Mobile ===================== */
  @media (max-width: 768px) {
    .hero,
    .hero__content {
      align-items: flex-start;
    }

    .work {
      padding: var(--space-act) 20px var(--space-rhythm);
    }

    .work__grid {
      grid-template-columns: 1fr;
    }

    .card:nth-child(n) {
      grid-column: 1 / -1;
    }

    .card__image img {
      aspect-ratio: 3 / 4;
    }

    .about {
      padding: var(--space-act) 20px;
    }

    .about__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .home-cta {
      padding: var(--space-act) 20px 0;
    }
  }
</style>
