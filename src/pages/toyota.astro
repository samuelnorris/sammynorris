---
import CaseStudyLayout from "../layouts/CaseStudyLayout.astro";

const meta = [
  { label: "Year", value: "2020" },
  { label: "Client", value: "Toyota" },
  { label: "Role", value: "Product Designer" },
  { label: "Agency", value: "Brandwidth" },
];
export const prerender = true;
---

<CaseStudyLayout
  pageTitle="Toyota — Sammy Norris"
  lede="Spec your perfect car, online."
  meta={meta}
  description="A web-based car configurator for Toyota, giving users the tools to spec their perfect vehicle from engine to interior — shipped through Brandwidth."
  signoff="Designed at Brandwidth"
  signoffYear="2020"
>
  <Fragment slot="title">Toyota</Fragment>

  <!-- Figure 01 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/toyota/image-toyota-1-m.jpg" />
      <img src="/images/projects/toyota/image-toyota-1.jpg" alt="Toyota configurator hero" loading="eager" />
    </picture>
  </figure>

  <!-- Chapter I — Challenge -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num">I.</span>
      <span class="chapter__label b2">The challenge</span>
    </header>

    <blockquote class="chapter__quote">
      Give people a tangible sense of ownership before they ever stepped into
      a dealership.
    </blockquote>

    <div class="chapter__body">
      <p class="b1">
        Working as part of the design team at Brandwidth, I contributed to a
        web-based configurator for Toyota that let users custom-build their
        cars online. The experience walked people through multiple stages of
        customisation — from comparing engine specs through to selecting
        luxury interior details.
      </p>
    </div>
  </section>

  <!-- Figure 02 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/toyota/image-toyota-2-m.jpg" />
      <img src="/images/projects/toyota/image-toyota-2.jpg" alt="Configurator build stages" loading="lazy" />
    </picture>
  </figure>

  <!-- Chapter II — Process -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num">II.</span>
      <span class="chapter__label b2">The process</span>
    </header>

    <h2 class="chapter__h2">
      Prototype, recolour, <em>test, repeat.</em>
    </h2>

    <div class="chapter__body">
      <p class="b1">
        My work sat across prototyping, visual asset production, and testing.
        I was responsible for the digital recolouring of vehicle assets in
        Photoshop, producing colour-accurate variants across Toyota's range
        so that every configuration felt authentic. Alongside that, I helped
        prototype interaction patterns for the build flow and ran wide-scale
        A/B tests on layout variants to validate design decisions with real
        user behaviour.
      </p>
    </div>
  </section>

  <!-- Figure 03 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/toyota/image-toyota-3-m.jpg" />
      <img src="/images/projects/toyota/image-toyota-3.jpg" alt="Recoloured Toyota assets" loading="lazy" />
    </picture>
  </figure>

  <!-- Chapter III — Outcome -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num">III.</span>
      <span class="chapter__label b2">The outcome</span>
    </header>

    <h2 class="chapter__h2">
      A formative one. <em>Shipped live.</em>
    </h2>

    <div class="chapter__body">
      <p class="b1">
        It was an early-career project for me, and a formative one — working
        at the pace and precision that a brand like Toyota demands, within a
        team that had to ship something production-ready. The configurator
        went live and gave me my first real exposure to large-scale,
        data-informed product design.
      </p>
    </div>
  </section>

  <!-- Figure 04 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/toyota/image-toyota-4-m.jpg" />
      <img src="/images/projects/toyota/image-toyota-4.jpg" alt="Toyota configurator detail" loading="lazy" />
    </picture>
  </figure>

  <!-- Figure 05 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/toyota/image-toyota-5-m.jpg" />
      <img src="/images/projects/toyota/image-toyota-5.jpg" alt="Toyota configurator screens" loading="lazy" />
    </picture>
  </figure>
</CaseStudyLayout>
