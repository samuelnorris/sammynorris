---
import Layout from "../layouts/Layout.astro";
import BackButton from "../components/BackButton.astro";
import BmxBike from "../components/BmxBike.astro";
// The ramp geometry is built at runtime (see the script below) so the world can
// adapt to the screen shape — wide on desktop, tall and filling the width on a
// portrait phone.
---

<Layout title="Halfpipe - Sammy Norris" description="A little BMX halfpipe trick game.">
  <nav class="case-nav">
    <BackButton href="/" label="Back to home" />
  </nav>

  <div class="game">
    <h1 class="visually-hidden">BMX Halfpipe trick game</h1>

    <div class="play-area">
    <div class="stage" id="stage">
      <div class="world" id="world">
        <svg class="ramp" id="ramp" viewBox="0 0 900 560" aria-hidden="true">
          <path class="ramp__fill" id="ramp-fill" />
          <path class="ramp__line" id="ramp-line" />
          <circle class="ramp__cope" id="cope-l" r="4" />
          <circle class="ramp__cope" id="cope-r" r="4" />
        </svg>

        <div class="bike" id="bike"><BmxBike /></div>
        <div class="pop" id="pop" aria-hidden="true"></div>
      </div>

      <!-- HUD -->
      <div class="hud" aria-hidden="true">
        <div class="hud__item"><span class="hud__label">Score</span><span id="hud-score">0</span></div>
        <div class="hud__combo" id="hud-combo"></div>
        <div class="hud__item hud__time"><span class="hud__label">Time</span><span id="hud-time">30</span></div>
      </div>

      <!-- Touch backflip button -->
      <button class="flip-btn" id="flip-btn" type="button" aria-label="Backflip">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3.5 12a8.5 8.5 0 1 1 2.2 5.7" />
          <path d="M3.5 17.5v-5h5" />
        </svg>
      </button>

      <!-- Start / controls overlay -->
      <div class="overlay" id="overlay-start">
        <div class="overlay__card">
          <p class="overlay__eyebrow">BMX</p>
          <h2 class="overlay__title">Halfpipe</h2>
          <ul class="controls controls--keys">
            <li><span class="key">←</span><span class="key">→</span><span>or</span><span class="key">A</span><span class="key">D</span> &nbsp;pump up the walls &amp; build speed</li>
            <li><span class="hint">In the air</span> tap <span class="key">←</span><span class="key">→</span> to <strong>spin 180°</strong> (tap again for more)</li>
            <li><span class="hint">Flip</span> tap <span class="key">↑</span><span class="key">↓</span> for back / front flips</li>
            <li><span class="hint">Auto-land</span> the bike always drops back in the right way up</li>
          </ul>
          <ul class="controls controls--touch">
            <li><span class="hint">Hold</span> anywhere to pump up the walls &amp; build speed</li>
            <li><span class="hint">In the air</span> tap the left / right side to <strong>spin 180°</strong> (tap again for more)</li>
            <li><span class="hint">Flip</span> tap the <span class="ico">↻</span> button to backflip - even just before you launch</li>
            <li><span class="hint">Auto-land</span> the bike always drops back in the right way up</li>
          </ul>
          <button class="overlay__btn" id="btn-start" type="button">Drop in</button>
        </div>
      </div>

      <!-- Game over overlay -->
      <div class="overlay overlay--hidden" id="overlay-end">
        <div class="overlay__card">
          <p class="overlay__eyebrow">Run over</p>
          <h2 class="overlay__title"><span id="end-score">0</span></h2>
          <p class="overlay__best" id="end-best">Best: 0</p>
          <form class="score-save" id="score-save">
            <input class="score-save__input" id="name-input" type="text" maxlength="14" placeholder="Your name" autocomplete="off" aria-label="Your name for the scoreboard" />
            <button class="score-save__btn" id="btn-save" type="submit">Save score</button>
          </form>
          <p class="score-saved" id="score-saved" hidden>Saved to the scoreboard&nbsp;✓</p>
          <button class="overlay__btn" id="btn-restart" type="button">Ride again</button>
        </div>
      </div>
    </div>

    <button class="board-btn" id="board-btn" type="button">
      <span aria-hidden="true">🏆</span> Scoreboard
    </button>
    </div>

    <!-- Scoreboard popup -->
    <div class="board-modal board-modal--hidden" id="board-modal" role="dialog" aria-modal="true" aria-label="Scoreboard">
      <div class="board-modal__card">
        <button class="board-modal__close" id="board-close" type="button" aria-label="Close scoreboard">&times;</button>
        <h2 class="board-modal__title">Scoreboard</h2>
        <ol class="board-list" id="board-list"></ol>
        <p class="board-empty" id="board-empty" hidden>No scores yet - drop in and set one.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .case-nav { position: fixed; top: 24px; left: 24px; z-index: 100; }

  .game {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 88px 24px 40px;
    box-sizing: border-box;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0; border: 0;
    clip: rect(0 0 0 0); clip-path: inset(50%);
    overflow: hidden; white-space: nowrap;
  }

  .stage {
    position: relative;
    width: 100%;
    max-width: 920px;
    aspect-ratio: 900 / 560;
    border-radius: 18px;
    overflow: hidden;
    outline: 1px solid color-mix(in srgb, var(--color-primary) 10%, transparent);
    outline-offset: -1px;
    box-shadow: 0 10px 40px -16px rgba(0, 0, 0, 0.4);
    background:
      linear-gradient(to bottom,
        var(--color-card-image-bg) 0%,
        var(--color-bg) 100%);
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;       /* iOS Safari ignores the unprefixed one */
    -webkit-touch-callout: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* Fixed logical 900x560 world, scaled to fit the stage by JS. */
  .world {
    position: absolute;
    top: 0; left: 0;
    width: 900px;
    height: 560px;
    transform-origin: top left;
  }

  .ramp { position: absolute; top: 0; left: 0; }
  .ramp__fill { fill: var(--color-card-bg); }
  .ramp__line {
    fill: none;
    stroke: var(--color-primary);
    stroke-opacity: 0.22;
    stroke-width: 2;
  }
  .ramp__cope { fill: var(--color-secondary); }

  .bike {
    position: absolute;
    top: 0; left: 0;
    width: 88px;
    /* pivot on the wheel axle line (~72% down the bike art) */
    transform-origin: 50% 72%;
    will-change: transform;
  }
  .bike :global(.bmx-bike) {
    width: 100%;
    height: auto;
    color: var(--color-primary);
  }

  .pop {
    position: absolute;
    top: 0; left: 0;
    transform: translate(-50%, -50%);
    font-family: var(--font-serif);
    font-size: 26px;
    color: var(--color-secondary);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
  }
  .pop.go { animation: popUp 1.1s ease-out forwards; }
  @keyframes popUp {
    0% { opacity: 0; transform: translate(-50%, -40%) scale(0.8); }
    18% { opacity: 1; transform: translate(-50%, -60%) scale(1); }
    100% { opacity: 0; transform: translate(-50%, -150%) scale(1); }
  }

  /* ---------- Touch flip button ---------- */
  .flip-btn {
    position: absolute;
    right: 18px;
    bottom: 18px;
    z-index: 5;
    width: 64px;
    height: 64px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--color-tertiary);
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    color: var(--color-primary);
    cursor: pointer;
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.1s ease, border-color 0.2s ease;
  }
  .stage.playing .flip-btn { display: flex; }
  .flip-btn:active { border-color: var(--color-secondary); transform: scale(0.94); }
  .flip-btn--armed {
    border-color: var(--color-secondary);
    color: var(--color-secondary);
    background: color-mix(in srgb, var(--color-secondary) 22%, var(--color-card-bg));
  }

  /* ---------- HUD ---------- */
  .hud {
    position: absolute;
    inset: 0;
    padding: 18px 22px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    pointer-events: none;
    font-family: var(--font-sans);
  }
  .hud__item { display: flex; flex-direction: column; gap: 2px; }
  .hud__time { text-align: right; }
  .hud__label {
    font-size: var(--text-b4);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.55;
    font-weight: 400;
  }
  .hud__item span:last-child {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1;
  }
  .hud__combo {
    margin-top: 2px;
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 3.5vw, 2rem);
    color: var(--color-secondary);
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .hud__combo.show { opacity: 1; transform: scale(1); }

  /* ---------- Overlays ---------- */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    background: color-mix(in srgb, var(--color-bg) 68%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: opacity 0.25s ease;
  }
  .overlay--hidden { opacity: 0; pointer-events: none; }

  .overlay__card {
    max-width: 440px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .overlay__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-b4);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-secondary);
    margin: 0;
  }
  .overlay__title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 8vw, 4rem);
    line-height: 0.95;
    font-weight: 400;
    margin: 0;
  }
  .overlay__best {
    font-family: var(--font-sans);
    font-size: var(--text-b2);
    opacity: 0.7;
    margin: 0;
  }
  .controls {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 300;
    line-height: 1.5;
    opacity: 0.85;
  }
  .controls li {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .controls strong { font-weight: 500; color: var(--color-primary); }
  .key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    border: 1px solid var(--color-tertiary);
    border-radius: 6px;
    font-size: var(--text-b4);
  }
  .hint {
    color: var(--color-secondary);
    font-weight: 400;
  }
  .ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border: 1px solid var(--color-tertiary);
    border-radius: 50%;
  }
  /* Show keyboard controls on pointer devices, touch controls on touchscreens. */
  .controls--touch { display: none; }
  @media (pointer: coarse) {
    .controls--keys { display: none; }
    .controls--touch { display: flex; }
  }
  .overlay__btn {
    margin-top: 8px;
    padding: 12px 28px;
    border-radius: 99px;
    border: 1px solid var(--color-tertiary);
    background: var(--color-card-bg);
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: var(--text-b2);
    font-weight: 400;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .overlay__btn:hover { border-color: var(--color-secondary); transform: translateY(-2px); }

  /* ---------- Play area + scoreboard button ---------- */
  .play-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
    max-width: 920px;
  }
  .board-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 99px;
    border: 1px solid var(--color-tertiary);
    background: var(--color-card-bg);
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 400;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .board-btn:hover { border-color: var(--color-secondary); transform: translateY(-2px); }

  /* ---------- Name entry on the game-over card ---------- */
  .score-save {
    display: flex;
    gap: 8px;
    width: 100%;
    max-width: 320px;
  }
  .score-save__input {
    flex: 1;
    min-width: 0;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid var(--color-tertiary);
    background: var(--color-card-image-bg);
    color: var(--color-primary);
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    user-select: text;
    -webkit-user-select: text;
  }
  .score-save__input:focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 1px;
  }
  .score-save__btn {
    padding: 10px 16px;
    border-radius: 10px;
    border: 1px solid var(--color-secondary);
    background: var(--color-secondary);
    color: var(--color-bg);
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
  }
  .score-save__btn:disabled { opacity: 0.5; cursor: default; }
  .score-saved {
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    color: var(--color-secondary);
    margin: 0;
  }

  /* ---------- Scoreboard popup ---------- */
  .board-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: color-mix(in srgb, var(--color-bg) 72%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: opacity 0.2s ease;
  }
  .board-modal--hidden { opacity: 0; pointer-events: none; }
  .board-modal__card {
    position: relative;
    width: 100%;
    max-width: 420px;
    max-height: 80vh;
    overflow-y: auto;
    padding: 32px 28px;
    border-radius: 18px;
    background: var(--color-card-bg);
    border: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
    box-shadow: 0 20px 60px -20px rgba(0, 0, 0, 0.5);
  }
  .board-modal__close {
    position: absolute;
    top: 14px;
    right: 16px;
    width: 32px;
    height: 32px;
    border: none;
    background: none;
    color: var(--color-primary);
    font-size: 26px;
    line-height: 1;
    opacity: 0.6;
    cursor: pointer;
  }
  .board-modal__close:hover { opacity: 1; }
  .board-modal__title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 400;
    margin: 0 0 20px;
  }
  .board-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: rank;
  }
  .board-list li {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    align-items: baseline;
    gap: 12px;
    padding: 10px 0;
    border-top: 1px solid color-mix(in srgb, var(--color-primary) 10%, transparent);
    font-family: var(--font-sans);
    font-size: var(--text-b2);
  }
  .board-list li::before {
    counter-increment: rank;
    content: counter(rank);
    color: var(--color-secondary);
    font-family: var(--font-serif);
    font-size: var(--text-b1);
  }
  .board-list li.is-new { color: var(--color-secondary); }
  .board-list .b-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .board-list .b-score { font-variant-numeric: tabular-nums; font-weight: 500; }
  .board-empty {
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    opacity: 0.7;
    margin: 0;
  }

  @media (max-width: 768px) {
    .case-nav { top: 16px; left: 16px; }
    /* Full-bleed: the play box fills the viewport, scoreboard button beneath it. */
    .game {
      padding: 0;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
    }
    .play-area {
      flex: 1;
      width: 100%;
      max-width: none;
      gap: 0;
    }
    /* Stage fills the space; the world auto-adapts to it (see layout() in JS). */
    .stage {
      flex: 1;
      width: 100%;
      max-width: none;
      height: auto;
      aspect-ratio: auto;
      border-radius: 0;
      outline: none;
      box-shadow: none;
    }
    /* Drop the HUD below the floating Back / Light buttons. */
    .hud { padding: 70px 16px 14px; }
    .hud__item span:last-child { font-size: 1.5rem; }
    .overlay { padding: 70px 18px 18px; }
    .overlay__card { gap: 12px; }
    .overlay__title { font-size: clamp(2rem, 12vw, 3rem); }
    .controls { font-size: var(--text-b4); gap: 8px; }
    .flip-btn { width: 78px; height: 78px; right: 16px; bottom: 16px; }
    .board-btn {
      padding: 12px 26px;
      font-size: var(--text-b2);
      margin: 12px auto calc(10px + env(safe-area-inset-bottom));
    }
  }
</style>

<script>
  // All these elements are static markup in this same component, so the
  // assertion is safe; the big runtime guard below is kept as a belt-and-braces.
  const $el = <T extends HTMLElement = HTMLElement>(id: string) =>
    document.getElementById(id) as T;
  const stage = $el("stage");
  const world = $el("world");
  const bike = $el("bike");
  const pop = $el("pop");
  const elScore = $el("hud-score");
  const elTime = $el("hud-time");
  const elCombo = $el("hud-combo");
  const ovStart = $el("overlay-start");
  const ovEnd = $el("overlay-end");
  const endScore = $el("end-score");
  const endBest = $el("end-best");
  const btnStart = $el("btn-start");
  const btnRestart = $el("btn-restart");
  const nameInput = $el<HTMLInputElement>("name-input");
  const scoreSaveForm = $el<HTMLFormElement>("score-save");
  const scoreSaved = $el("score-saved");
  const boardBtn = $el("board-btn");
  const boardModal = $el("board-modal");
  const boardClose = $el<HTMLButtonElement>("board-close");
  const boardList = $el("board-list");
  const boardEmpty = $el("board-empty");
  const rampSvg = document.getElementById("ramp") as Element | null;
  const rampFill = document.getElementById("ramp-fill") as Element | null;
  const rampLine = document.getElementById("ramp-line") as Element | null;
  const copeL = document.getElementById("cope-l") as Element | null;
  const copeR = document.getElementById("cope-r") as Element | null;

  if (stage && world && bike && pop && elScore && elTime && elCombo &&
      ovStart && ovEnd && endScore && endBest && btnStart && btnRestart) {

    // ---- Geometry (rebuilt by layout() to fit the screen shape) ----
    const RSURF = 230;                   // ramp surface radius (logical px; fixes the feel)
    const LIP = (85 * Math.PI) / 180;
    let WORLD_W = 900, WORLD_H = 560;    // logical world size, set per screen
    let CX = 450, CY = 250;              // bowl centre, set per screen
    let BW = 0, BH = 0, ORIGIN_X = 0, ORIGIN_Y = 0, WHEEL_R = 0, Rc = 0;
    function setBike(w: number) {
      BW = w;                            // bike width in logical px
      BH = BW * (268 / 380);             // height from the SVG aspect
      ORIGIN_X = BW / 2;
      ORIGIN_Y = BH * 0.7201;            // wheel axle line
      WHEEL_R = (61.4 / 380) * BW;       // tyre radius in logical px
      Rc = RSURF - WHEEL_R;              // pivot path radius (wheels touch the surface)
    }
    setBike(88);

    // ---- Tunables ----
    const G = 2100;          // gravity (px/s^2)
    const PUMP = 1.9;        // energy gain when pumping with motion (per s)
    const BRAKE = 2.6;       // energy loss when holding against motion
    const PHIVEL_MAX = 4.6;  // swing-speed cap -> caps air height (keeps airs on-screen)
    const SPIN_RATE = 760;   // flat-spin speed (deg/s) the bike rotates toward its target
    const FLIP_RATE = 720;   // back / front flip speed (deg/s)
    const TILT_EASE = 6;     // how fast the wall-lean levels out in the air
    const RUN_TIME = 30;

    const DEG = 180 / Math.PI;

    const s = {
      mode: "ready",          // ready | play | over
      phi: -0.6, phiVel: 0,
      airborne: false,
      x: 0, y: 0, vx: 0, vy: 0,
      rot: 0.6,               // wall-lean tilt (radians)
      spin: 0, spinTarget: 0, // flat spin about the vertical axis (degrees)
      flip: 0, flipTarget: 0, // back / front flip about the screen axis (degrees)
      flipQueued: false,      // touch: a backflip pre-loaded for the next launch
      face: 1,
      input: 0,
      autoPump: false, pumpKick: 1,   // touch: hold anywhere to pump
      score: 0, combo: 1, final: 0,
      time: RUN_TIME,
      best: 0,
    };
    try { s.best = parseInt(localStorage.getItem("bmx-best") || "0", 10) || 0; } catch {}

    // ---- Responsive world layout ----
    function buildRamp() {
      const pts: [number, number][] = [];
      for (let a = -LIP; a <= LIP + 1e-6; a += 0.03) {
        pts.push([CX + RSURF * Math.sin(a), CY + RSURF * Math.cos(a)]);
      }
      const line = pts.map((p, i) => (i ? "L" : "M") + p[0].toFixed(1) + " " + p[1].toFixed(1)).join(" ");
      const fill = "M0 " + WORLD_H + " " +
        pts.map((p) => "L" + p[0].toFixed(1) + " " + p[1].toFixed(1)).join(" ") +
        " L" + WORLD_W + " " + WORLD_H + " Z";
      if (rampSvg) {
        rampSvg.setAttribute("viewBox", "0 0 " + WORLD_W + " " + WORLD_H);
        rampSvg.setAttribute("width", String(WORLD_W));
        rampSvg.setAttribute("height", String(WORLD_H));
      }
      rampFill && rampFill.setAttribute("d", fill);
      rampLine && rampLine.setAttribute("d", line);
      const a0 = pts[0], a1 = pts[pts.length - 1];
      if (copeL) { copeL.setAttribute("cx", String(a0[0])); copeL.setAttribute("cy", String(a0[1])); }
      if (copeR) { copeR.setAttribute("cx", String(a1[0])); copeR.setAttribute("cy", String(a1[1])); }
    }
    function layout() {
      const w = stage.clientWidth, hgt = stage.clientHeight;
      if (!w || !hgt) return;
      const aspect = hgt / w;                  // > 1 means portrait
      const portrait = aspect > 1.05;
      const bowlHalf = RSURF * Math.sin(LIP);
      const side = portrait ? 48 : 226;        // deck width each side of the bowl
      WORLD_W = Math.round(2 * (bowlHalf + side));
      WORLD_H = Math.round(WORLD_W * aspect);  // fills the stage height exactly
      CX = WORLD_W / 2;
      CY = WORLD_H - (portrait ? 96 : 80) - RSURF;  // bowl near the bottom, sky above
      setBike(portrait ? 104 : 88);
      buildRamp();
      world.style.width = WORLD_W + "px";
      world.style.height = WORLD_H + "px";
      world.style.transform = "scale(" + w / WORLD_W + ")";
    }
    layout();
    new ResizeObserver(layout).observe(stage);

    function ridePos(phi: number) { return { x: CX + Rc * Math.sin(phi), y: CY + Rc * Math.cos(phi) }; }

    function reset(full: boolean) {
      s.phi = -0.6; s.phiVel = 0;
      s.airborne = false;
      s.rot = 0.6; s.spin = 0; s.spinTarget = 0; s.flip = 0; s.flipTarget = 0;
      s.flipQueued = false;
      s.input = 0; s.face = 1;
      s.autoPump = false; s.pumpKick = 1;
      if (full) { s.score = 0; s.combo = 1; s.time = RUN_TIME; }
    }

    function showPop(text: string) {
      const p = s.airborne ? { x: s.x, y: s.y } : ridePos(s.phi);
      pop.textContent = text;
      pop.style.left = Math.max(50, Math.min(WORLD_W - 50, p.x)) + "px";
      pop.style.top = Math.max(50, Math.min(WORLD_H - 50, p.y - 46)) + "px";
      pop.classList.remove("go");
      void pop.offsetWidth;   // restart the animation
      pop.classList.add("go");
    }

    function launch() {
      s.airborne = true;
      const cos = Math.cos(s.phi), sin = Math.sin(s.phi);
      const p = ridePos(s.phi);
      s.x = p.x; s.y = p.y;
      s.vx = s.phiVel * Rc * cos;
      s.vy = -s.phiVel * Rc * sin;
      s.rot = -s.phi;
      s.spin = 0; s.spinTarget = 0;
      s.flip = 0;
      s.flipTarget = s.flipQueued ? -360 : 0;   // fire a pre-loaded backflip on launch
      s.flipQueued = false;
    }

    function land() {
      const dxC = s.x - CX, dyC = s.y - CY;
      let phi = Math.atan2(dxC, dyC);
      if (phi > LIP) phi = LIP; else if (phi < -LIP) phi = -LIP;
      const cos = Math.cos(phi), sin = Math.sin(phi);

      // Tricks auto-correct on landing, so the bike always comes down wheels-down.
      const halves = Math.round(s.spin / 180);    // completed 180 flat-spins
      const flips = Math.round(s.flip / 360);     // completed back / front flips
      s.airborne = false;
      s.phi = phi;
      s.rot = -phi;                               // settle onto the wall
      s.spin = 0; s.spinTarget = 0;
      s.flip = 0; s.flipTarget = 0;
      s.phiVel = (s.vx * cos - s.vy * sin) / Rc;  // keep rolling

      const deg = Math.abs(halves) * 180 + Math.abs(flips) * 360;
      if (deg !== 0) {
        const pts = deg * s.combo;
        s.score += pts;
        const label = flips !== 0 && halves === 0
          ? (Math.abs(flips) > 1 ? Math.abs(flips) + "× " : "") + (flips < 0 ? "Backflip" : "Frontflip")
          : deg + "°";
        showPop(label + "  +" + pts);
        s.combo = Math.min(s.combo + 1, 9);
      }
    }

    function step(h: number) {
      if (s.mode !== "play") return;

      s.time -= h;
      if (s.time <= 0) { s.time = 0; endRun(); return; }

      if (!s.airborne) {
        const aa = -(G / Rc) * Math.sin(s.phi);
        s.phiVel += aa * h;

        // Touch "hold anywhere to pump": a held finger follows the current swing so
        // it always pumps (kicking off toward the touched side from rest).
        if (s.autoPump) {
          s.input = Math.abs(s.phiVel) < 0.05 ? s.pumpKick : (s.phiVel > 0 ? 1 : -1);
        }

        if (s.input !== 0) {
          if (Math.abs(s.phiVel) < 0.05) {
            s.phiVel += s.input * 0.7;            // kick off from rest
          } else if (Math.sign(s.phiVel) === s.input) {
            s.phiVel *= 1 + PUMP * h;             // pump
          } else {
            s.phiVel *= 1 - BRAKE * h;            // brake
          }
        }
        s.phiVel = Math.max(-PHIVEL_MAX, Math.min(PHIVEL_MAX, s.phiVel));
        s.phi += s.phiVel * h;
        s.rot = -s.phi;
        if (Math.abs(s.phiVel) > 0.1) s.face = s.phiVel > 0 ? 1 : -1;

        if (Math.abs(s.phi) >= LIP && Math.sign(s.phi) === Math.sign(s.phiVel)) {
          launch();
        } else if (Math.abs(s.phi) > LIP) {
          s.phi = Math.sign(s.phi) * LIP;
          s.phiVel *= 0.3;
        }
      } else {
        s.vy += G * h;
        s.x += s.vx * h;
        s.y += s.vy * h;
        // Keep the bike within the pipe mouth: outward drift rides the lip and drops back in.
        const lipX = Rc * Math.sin(LIP);
        if (s.x > CX + lipX) { s.x = CX + lipX; if (s.vx > 0) s.vx = 0; }
        else if (s.x < CX - lipX) { s.x = CX - lipX; if (s.vx < 0) s.vx = 0; }
        if (Math.abs(s.vx) > 12) s.face = s.vx > 0 ? 1 : -1;

        // Auto-level the wall lean and ease the spin & flip toward their targets.
        s.rot += (0 - s.rot) * Math.min(1, TILT_EASE * h);
        const dsp = s.spinTarget - s.spin, spinStep = SPIN_RATE * h;
        s.spin += Math.max(-spinStep, Math.min(spinStep, dsp));
        const dfl = s.flipTarget - s.flip, flipStep = FLIP_RATE * h;
        s.flip += Math.max(-flipStep, Math.min(flipStep, dfl));

        // Land when the bike falls back onto the bowl surface while descending.
        const dxs = s.x - CX;
        if (s.vy > 0 && Math.abs(dxs) < Rc) {
          const ySurf = CY + Math.sqrt(Rc * Rc - dxs * dxs);
          if (s.y >= ySurf) land();
        }
        if (s.y > WORLD_H + 120) reset(false);
      }
    }

    function render() {
      let px, py;
      if (s.airborne) { px = s.x; py = s.y; }
      else { const p = ridePos(s.phi); px = p.x; py = p.y; }
      bike.style.transform =
        `translate(${px - ORIGIN_X}px, ${py - ORIGIN_Y}px) perspective(640px) ` +
        `rotateY(${s.spin}deg) rotate(${s.rot * DEG + s.flip}deg) scaleX(${s.face})`;
      if (flipBtn) flipBtn.classList.toggle("flip-btn--armed", s.flipQueued);

      elScore.textContent = String(Math.round(s.score));
      elTime.textContent = String(Math.ceil(s.time));
      if (s.combo > 1) { elCombo.textContent = "x" + s.combo; elCombo.classList.add("show"); }
      else elCombo.classList.remove("show");
    }

    let last = 0, acc = 0;
    const FIXED = 1 / 120;
    function frame(now: number) {
      if (!last) last = now;
      let dt = (now - last) / 1000;
      last = now;
      if (dt > 0.1) dt = 0.1;
      acc += dt;
      while (acc >= FIXED) { step(FIXED); acc -= FIXED; }
      render();
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    // ---- Flow ----
    function startRun() {
      reset(true);
      applyKeys();   // honour a direction key that's already held down
      s.mode = "play";
      stage.classList.add("playing");
      ovStart.classList.add("overlay--hidden");
      ovEnd.classList.add("overlay--hidden");
    }
    function endRun() {
      s.mode = "over";
      s.input = 0;
      stage.classList.remove("playing");
      s.final = Math.round(s.score);
      if (s.final > s.best) {
        s.best = s.final;
        try { localStorage.setItem("bmx-best", String(s.best)); } catch {}
      }
      endScore.textContent = String(s.final);
      endBest.textContent = "Best: " + s.best;
      resetSaveForm();
      ovEnd.classList.remove("overlay--hidden");
    }
    btnStart.addEventListener("click", startRun);
    btnRestart.addEventListener("click", startRun);

    // ---- Scoreboard (saved in this browser) ----
    const SCORE_KEY = "bmx-scores";
    const NAME_KEY = "bmx-name";
    type ScoreRow = { name: string; score: number };
    function loadScores(): ScoreRow[] {
      try { return JSON.parse(localStorage.getItem(SCORE_KEY) || "[]") || []; }
      catch { return []; }
    }
    function fmtName(v: string) { return (v || "").trim().slice(0, 14) || "Rider"; }
    function resetSaveForm() {
      if (!scoreSaveForm) return;
      scoreSaveForm.hidden = false;
      if (scoreSaved) scoreSaved.hidden = true;
      if (nameInput) {
        try { nameInput.value = localStorage.getItem(NAME_KEY) || ""; } catch { nameInput.value = ""; }
      }
    }
    function doSave() {
      if (!scoreSaveForm || scoreSaveForm.hidden) return;   // already saved this run
      const name = fmtName(nameInput ? nameInput.value : "");
      try { localStorage.setItem(NAME_KEY, name); } catch {}
      const list = loadScores();
      list.push({ name, score: s.final });
      list.sort((a, b) => b.score - a.score);
      try { localStorage.setItem(SCORE_KEY, JSON.stringify(list.slice(0, 20))); } catch {}
      scoreSaveForm.hidden = true;
      if (scoreSaved) scoreSaved.hidden = false;
    }
    function renderBoard() {
      if (!boardList) return;
      const list = loadScores();
      boardList.innerHTML = "";
      if (boardEmpty) boardEmpty.hidden = list.length > 0;
      list.forEach((row) => {
        const li = document.createElement("li");
        const name = document.createElement("span");
        name.className = "b-name";
        name.textContent = row.name;
        const score = document.createElement("span");
        score.className = "b-score";
        score.textContent = String(row.score);
        li.append(name, score);
        boardList.appendChild(li);
      });
    }
    let resumeMode: "play" | null = null;
    let boardReturnFocus: Element | null = null;
    function openBoard() {
      renderBoard();
      boardModal?.classList.remove("board-modal--hidden");
      if (s.mode === "play") { resumeMode = "play"; s.mode = "paused"; }  // pause a live run
      // aria-modal hides the rest of the page from AT, so focus must move
      // into the dialog (and back out again on close).
      boardReturnFocus = document.activeElement;
      boardClose?.focus();
    }
    function closeBoard() {
      boardModal?.classList.add("board-modal--hidden");
      if (resumeMode === "play") { s.mode = "play"; resumeMode = null; }
      if (boardReturnFocus instanceof HTMLElement) boardReturnFocus.focus();
      boardReturnFocus = null;
    }
    scoreSaveForm?.addEventListener("submit", (e) => { e.preventDefault(); doSave(); });
    boardBtn?.addEventListener("click", openBoard);
    boardClose?.addEventListener("click", closeBoard);
    boardModal?.addEventListener("click", (e) => { if (e.target === boardModal) closeBoard(); });
    // Keep Tab cycling within the dialog while it's open.
    boardModal?.addEventListener("keydown", (e) => {
      if (e.key !== "Tab") return;
      const focusables = boardModal.querySelectorAll<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      if (!focusables.length) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault(); last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault(); first.focus();
      }
    });

    // ---- Input ----
    const keyL = new Set(["ArrowLeft", "KeyA"]);
    const keyR = new Set(["ArrowRight", "KeyD"]);
    const keyFlipBack = new Set(["ArrowUp", "KeyW"]);
    const keyFlipFwd = new Set(["ArrowDown", "KeyS"]);
    const down = new Set();
    function applyKeys() {
      const l = [...keyL].some((k) => down.has(k));
      const r = [...keyR].some((k) => down.has(k));
      s.input = l && !r ? -1 : r && !l ? 1 : 0;
    }
    // Each tap adds 180° of trick spin (left = anticlockwise, right = clockwise).
    function addSpin(dir: number) {
      s.spinTarget = Math.max(-1080, Math.min(1080, s.spinTarget + dir * 180));
    }
    // Each tap adds a full flip (back = -1 tips backward, front = +1 tips forward).
    function addFlip(dir: number) {
      s.flipTarget = Math.max(-1080, Math.min(1080, s.flipTarget + dir * 360));
    }
    window.addEventListener("keydown", (e) => {
      if (e.target instanceof HTMLInputElement) return;   // let them type their name freely
      if (boardModal && !boardModal.classList.contains("board-modal--hidden")) {
        if (e.code === "Escape") closeBoard();
        return;                                           // ignore game keys while the board is open
      }
      if (e.code === "Space") e.preventDefault();   // never scroll the page mid-run
      if ((e.code === "Space" || e.code === "Enter") && s.mode !== "play") {
        e.preventDefault(); startRun(); return;
      }
      if (keyL.has(e.code) || keyR.has(e.code)) {
        e.preventDefault();
        if (s.mode === "play" && s.airborne && !e.repeat) addSpin(keyL.has(e.code) ? -1 : 1);
        down.add(e.code); applyKeys();
      } else if (keyFlipBack.has(e.code) || keyFlipFwd.has(e.code)) {
        e.preventDefault();
        if (s.mode === "play" && s.airborne && !e.repeat) addFlip(keyFlipBack.has(e.code) ? -1 : 1);
      }
    });
    window.addEventListener("keyup", (e) => {
      if (down.has(e.code)) { down.delete(e.code); applyKeys(); }
    });

    function pointerDir(clientX: number) {
      const r = stage.getBoundingClientRect();
      return clientX < r.left + r.width / 2 ? -1 : 1;
    }
    let activePointer: number | null = null;
    stage.addEventListener("pointerdown", (e) => {
      if (s.mode !== "play") return;
      if (s.airborne) { addSpin(pointerDir(e.clientX)); return; }  // tap = one 180 in the air
      activePointer = e.pointerId;
      stage.setPointerCapture?.(e.pointerId);
      if (e.pointerType === "mouse") {
        s.input = pointerDir(e.clientX);              // desktop: the side sets the direction
      } else {
        s.autoPump = true;                            // touch: hold anywhere to pump
        s.pumpKick = pointerDir(e.clientX);           // ...kicking off toward the touched side
      }
    });
    stage.addEventListener("pointermove", (e) => {
      if (s.mode !== "play" || e.pointerId !== activePointer) return;
      if (e.pointerType === "mouse") s.input = pointerDir(e.clientX);
    });
    const clearPointer = (e?: PointerEvent) => {
      if (e && e.pointerId !== activePointer) return;   // ignore other fingers lifting
      activePointer = null;
      s.autoPump = false;
      if (s.mode === "play") s.input = 0;
    };
    stage.addEventListener("pointerup", clearPointer);
    stage.addEventListener("pointercancel", clearPointer);

    // iOS Safari ignores touch-action for double-tap-zoom and pinch on the play
    // surface, so block those gestures while a run is live (tapping/holding to
    // pump no longer zooms the page). Overlays/score entry stay untouched.
    let lastTouchEnd = 0;
    stage.addEventListener("touchend", (e) => {
      if (s.mode !== "play") return;
      const now = performance.now();
      if (now - lastTouchEnd < 350) e.preventDefault();   // kill double-tap zoom
      lastTouchEnd = now;
    }, { passive: false });
    const blockGesture = (e: Event) => e.preventDefault();  // kill pinch zoom
    stage.addEventListener("gesturestart", blockGesture);
    stage.addEventListener("gesturechange", blockGesture);

    // Touch backflip button (doesn't trigger a spin via the stage handler)
    const flipBtn = document.getElementById("flip-btn");
    flipBtn?.addEventListener("pointerdown", (e) => {
      if (s.mode !== "play") return;
      e.preventDefault();
      e.stopPropagation();
      if (s.airborne) addFlip(-1);     // in the air: backflip now
      else s.flipQueued = true;        // on the ground: pre-load it for the next launch
    });
  }
</script>
