---
import Layout from "../layouts/Layout.astro";
import BackButton from "../components/BackButton.astro";
---

<Layout title="About - Sammy Norris">

  <!-- Back nav -->
  <nav class="case-nav">
    <BackButton href="/#about" label="Back to home" />
  </nav>

  <!-- Hero -->
  <header class="hero">
    <h1 class="hero__title" data-reveal style="--delay: 0.06s">
      <span id="greeting" class="hero__greeting">Hello</span>
    </h1>

  </header>

  <!-- Body -->
  <section class="about-body" data-reveal>
    <p class="b1">
      I design digital products in places where complexity is the default
      and clarity is the work - automotive, finance, and the corners of the
      internet where someone has to make a hard decision feel simple.
    </p>
    <p class="b1">
      I've worked across the full product lifecycle - early discovery,
      service design, prototyping, testing, delivery. Customer-facing tools
      like car configurators and connected vehicle apps. Large-scale
      regulatory services delivered under tight timelines. The work usually
      sits at the intersection of UI, UX, research, accessibility, and a
      lot of conversations with engineering, legal, and compliance.
    </p>
    <p class="b1">
      I currently work as a Senior Product Designer at Close Brothers,
      designing digital journeys that balance customer needs, business
      goals, and regulatory requirements.
    </p>
    <p class="b1">
      My approach is practical and evidence-led. Clarity over novelty. Test
      assumptions early. Focus on outcomes, not outputs. I try to design
      things that hold up in the real world, not just in a portfolio
      screenshot - which is probably why most of my work lives behind a
      login.
    </p>
  </section>

  <!-- Timeline -->
  <section class="timeline" data-reveal>
    <div class="timeline__pills" role="tablist" aria-label="Career timeline">
      <button class="timeline__pill active" type="button" role="tab" id="tl-tab-0" aria-controls="tl-panel-0" aria-selected="true" tabindex="0" data-tab="0">Present - 2021</button>
      <button class="timeline__pill" type="button" role="tab" id="tl-tab-1" aria-controls="tl-panel-1" aria-selected="false" tabindex="-1" data-tab="1">2021 - 2020</button>
      <button class="timeline__pill" type="button" role="tab" id="tl-tab-2" aria-controls="tl-panel-2" aria-selected="false" tabindex="-1" data-tab="2">2020 - 2018</button>
      <button class="timeline__pill" type="button" role="tab" id="tl-tab-3" aria-controls="tl-panel-3" aria-selected="false" tabindex="-1" data-tab="3">2017 - 2015</button>
      <span class="timeline__chevron" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6" />
        </svg>
      </span>
    </div>
    <div class="timeline__panels">
      <div class="timeline__panel active" id="tl-panel-0" role="tabpanel" aria-labelledby="tl-tab-0" tabindex="0" data-panel="0">
        <h2 class="timeline__company">Close Brothers</h2>
        <span class="timeline__role b3">Senior Product Designer</span>
        <p class="timeline__desc b2">Designing digital services across motor finance, asset finance, and insurance - all under FCA regulation. Led the Commission Disclosure and Consent service from brief to launch in seven weeks, and designed Ekeg+, a pay-per-fill keg rental platform managing over 400,000 containers. The work sits at the intersection of customer needs, business goals, and compliance.</p>
      </div>
      <div class="timeline__panel" id="tl-panel-1" role="tabpanel" aria-labelledby="tl-tab-1" tabindex="0" data-panel="1">
        <h2 class="timeline__company">Larkbury Group</h2>
        <span class="timeline__role b3">Product Designer / Graphic Designer</span>
        <p class="timeline__desc b2">Built Larkbury London from scratch - brand identity through to a fully responsive luxury ecommerce site across 700+ artboards and seven viewports. Maintained three primary brands - Larkbury Curtains, Luxsale, and The Sofa &amp; Chair Company - including brand guidelines, visual identity, and point-of-sale materials.</p>
      </div>
      <div class="timeline__panel" id="tl-panel-2" role="tabpanel" aria-labelledby="tl-tab-2" tabindex="0" data-panel="2">
        <h2 class="timeline__company">Brandwidth</h2>
        <span class="timeline__role b3">Product Designer</span>
        <p class="timeline__desc b2">Worked on connected vehicle and automotive experiences for Porsche and Toyota. Designed a native Apple Watch app giving Porsche owners glanceable access to their car's key stats, and owned the design execution across 70%+ of screens for Toyota's web-based car configurator.</p>
      </div>
      <div class="timeline__panel" id="tl-panel-3" role="tabpanel" aria-labelledby="tl-tab-3" tabindex="0" data-panel="3">
        <h2 class="timeline__company">Internet Fusion Group</h2>
        <span class="timeline__role b3">Middleweight UI / Graphic Designer</span>
        <p class="timeline__desc b2">As the lead designer, I managed the online content for 7 top level domains in 5 languages. This also involved advising on ecommerce best practices to optimise the customer journey and UX.</p>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" data-reveal>
    <h2 class="contact__h2">
      Want to chat? <em>Drop me a line.</em>
    </h2>
    <a href="mailto:hello@sammynorris.com" class="contact__cta" aria-label="Email Sammy">
      <span class="contact__cta-label">hello@sammynorris.com</span>
      <span class="contact__cta-icon">
        <svg aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </span>
    </a>
  </section>

  <!-- Footer -->
  <footer class="case-footer">
    <span class="b4">&copy; 2026 Sammy Norris</span>
  </footer>

</Layout>

<script>
  // Hero greeting: type a greeting, hold, delete, type the next language, loop
  (() => {
    const el = document.getElementById('greeting');
    if (!el || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const greetings = [
      { t: 'Hello',     lang: 'en' },
      { t: 'Bonjour',   lang: 'fr' },
      { t: 'Hola',      lang: 'es' },
      { t: 'Ciao',      lang: 'it' },
      { t: 'Olá',       lang: 'pt' },
      { t: 'Hej',       lang: 'sv' },
      { t: 'مرحبا', lang: 'ar', dir: 'rtl' },
      { t: 'Привет', lang: 'ru' },
      { t: 'こんにちは', lang: 'ja' },
      { t: '안녕',  lang: 'ko' },
      { t: '你好',  lang: 'zh' },
      { t: 'नमस्ते', lang: 'hi' },
    ];
    const typeSpeed = 110, deleteSpeed = 55, holdFull = 1300, holdEmpty = 250;
    const stopAt = Date.now() + 120000;

    let gi = 0;
    el.textContent = '';
    el.classList.add('hero__greeting--typing');

    const typeWord = (g, i) => {
      if (i === 0) { el.lang = g.lang; el.dir = g.dir || 'ltr'; }
      el.textContent = g.t.slice(0, i);
      if (i < g.t.length) setTimeout(() => typeWord(g, i + 1), typeSpeed);
      else if (Date.now() >= stopAt) el.classList.remove('hero__greeting--typing');
      else setTimeout(() => deleteWord(g, g.t.length), holdFull);
    };
    const deleteWord = (g, i) => {
      el.textContent = g.t.slice(0, i);
      if (i > 0) setTimeout(() => deleteWord(g, i - 1), deleteSpeed);
      else {
        gi = (gi + 1) % greetings.length;
        setTimeout(() => typeWord(greetings[gi], 0), holdEmpty);
      }
    };
    typeWord(greetings[gi], 0);
  })();

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));

  // Hide chevron when pills are scrolled to end
  const pillsContainer = document.querySelector('.timeline__pills');
  const chevron = document.querySelector('.timeline__chevron');
  if (pillsContainer && chevron) {
    pillsContainer.addEventListener('scroll', () => {
      const atEnd = pillsContainer.scrollLeft + pillsContainer.clientWidth >= pillsContainer.scrollWidth - 8;
      (chevron as HTMLElement).style.opacity = atEnd ? '0' : '0.3';
    });
  }

  // Timeline tabs (ARIA tablist: roving tabindex + arrow-key navigation)
  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.timeline__pill'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.timeline__panel'));

  const selectTab = (idx: number, setFocus: boolean) => {
    tabs.forEach((tab, i) => {
      const selected = i === idx;
      tab.classList.toggle('active', selected);
      tab.setAttribute('aria-selected', selected ? 'true' : 'false');
      tab.tabIndex = selected ? 0 : -1;
      if (selected && setFocus) tab.focus();
    });
    panels.forEach((panel, i) => panel.classList.toggle('active', i === idx));

    // Scroll active pill to centre on mobile
    if (pillsContainer && window.innerWidth <= 768) {
      const tab = tabs[idx];
      const left = tab.offsetLeft - pillsContainer.clientWidth / 2 + tab.offsetWidth / 2;
      pillsContainer.scrollTo({ left, behavior: 'smooth' });
    }
  };

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => selectTab(i, false));
    tab.addEventListener('keydown', (e) => {
      let next: number | null = null;
      if (e.key === 'ArrowRight') next = (i + 1) % tabs.length;
      else if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
      else if (e.key === 'Home') next = 0;
      else if (e.key === 'End') next = tabs.length - 1;
      if (next === null) return;
      e.preventDefault();
      selectTab(next, true);
    });
  });
</script>

<style>
  /* ===== Back nav ===== */
  .case-nav { position: fixed; top: 24px; left: 24px; z-index: 100; }

  /* ===== Hero ===== */
  .hero {
    padding: 160px 10vw 32px;
    display: flex;
    flex-direction: column;
  }
  .hero__eyebrow { color: var(--color-secondary); font-weight: 300; margin-bottom: 16px; }
  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    font-weight: 400;
    margin: 0 0 32px;
  }
  .hero__title em { font-style: italic; color: var(--color-secondary); }
  .hero__greeting--typing::after {
    content: "";
    display: inline-block;
    width: 2px;
    height: 0.8em;
    background: var(--color-primary);
    margin-left: 4px;
    vertical-align: baseline;
    animation: blink 1s ease-in-out infinite;
  }

  @keyframes blink { 50% { opacity: 0; } }
  .hero__lede {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.3;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--color-primary);
    opacity: 0.85;
  }

  /* ===== Body ===== */
  .about-body {
    padding: 0 10vw;
    margin: 0 0 96px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: calc(72ch + 160px + 10vw);
  }

  /* ===== Timeline ===== */
  .timeline {
    padding: 0 10vw;
    margin: 0 0 96px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: calc(72ch + 160px + 10vw);
  }

  .timeline__pills {
    display: flex;
    gap: 10px;
    position: relative;
  }

  .timeline__pill {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
    padding: 8px 20px;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-tertiary);
    border-radius: 99px;
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 300;
    letter-spacing: -0.01em;
    color: var(--color-primary);
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .timeline__chevron { display: none; }

  .timeline__pill:hover { border-color: var(--color-primary); }
  .timeline__pill.active { border-color: var(--color-secondary); color: var(--color-secondary); }

  .timeline__panel {
    display: none;
    flex-direction: column;
    gap: 8px;
  }

  .timeline__panel.active { display: flex; }

  .timeline__company {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    font-weight: 400;
    margin: 0;
  }

  .timeline__role {
    color: var(--color-secondary);
  }

  .timeline__desc {
    font-weight: 200;
    line-height: 1.6;
    margin: 4px 0 0;
  }

  /* ===== Contact ===== */
  .contact {
    padding: 96px 10vw 0;
    margin: 0 0 96px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    border-top: 1px solid color-mix(in srgb, var(--color-primary) 12%, transparent);
  }
  .contact__h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.15;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 80%;
  }
  .contact__h2 em { font-style: italic; opacity: 0.6; }

  .contact__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 4px 4px 16px;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-tertiary);
    border-radius: 99px;
    text-decoration: none;
    color: var(--color-primary);
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.3s ease;
  }
  .contact__cta:hover { border-color: var(--color-primary); }
  .contact__cta-label {
    font-family: var(--font-sans);
    font-size: var(--text-b3);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.4;
  }
  .contact__cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 100px;
    background-color: var(--color-card-image-bg);
    flex-shrink: 0;
  }

  /* ===== Footer ===== */
  .case-footer {
    padding: 64px 10vw;
    display: flex;
    justify-content: flex-start;
    color: var(--color-primary);
    opacity: 0.65;
  }

  /* ===== Reveal ===== */
  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0s),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0s);
  }
  [data-reveal].revealed { opacity: 1; transform: translateY(0); }

  /* ===== Mobile ===== */
  @media (max-width: 768px) {
    .case-nav { top: 20px; left: 20px; }
    .hero { padding: 96px 20px 24px; }
    .hero__title { font-size: clamp(2.5rem, 11vw, 3.5rem); margin-bottom: 20px; }
    .hero__lede { font-size: clamp(1.125rem, 4.5vw, 1.375rem); }
    .about-body { padding: 0 20px; margin-bottom: 64px; gap: 20px; }
    .timeline { padding: 0; margin-bottom: 64px; gap: 40px; }
    .timeline__pills {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 0 20px;
      mask-image: linear-gradient(to right, black calc(100% - 40px), transparent);
      -webkit-mask-image: linear-gradient(to right, black calc(100% - 40px), transparent);
    }
    .timeline__pills::-webkit-scrollbar { display: none; }
    .timeline__panels { padding: 0 20px; }
    .timeline__chevron {
      display: flex;
      align-items: center;
      flex-shrink: 0;
      color: var(--color-primary);
      opacity: 0.3;
      animation: nudge 1.5s ease-in-out infinite;
    }
    @keyframes nudge {
      0%, 100% { transform: translateX(0); }
      50% { transform: translateX(4px); }
    }
    .contact { padding: 64px 20px 0; margin-bottom: 64px; gap: 24px; }
    .contact__h2 { font-size: clamp(1.625rem, 7vw, 2rem); max-width: 100%; }
    .case-footer { padding: 40px 20px; }
  }
</style>
