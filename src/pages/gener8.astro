---
import CaseStudyLayout from "../layouts/CaseStudyLayout.astro";

const meta = [
  { label: "Year", value: "2021" },
  { label: "Client", value: "Gener8" },
  { label: "Role", value: "Lead Product Designer" },
  { label: "Timeline", value: "3 months" },
];

const stats = [
  { value: "200k+", label: "Downloads" },
  { value: "120k", label: "Daily users" },
  { value: "7mo", label: "To Dragons' Den" },
  { value: "1", label: "Sole designer" },
];
export const prerender = true;
---

<CaseStudyLayout
  pageTitle="Gener8 — Sammy Norris"
  caseNumber="03"
  lede="Flipping the ad model on its head."
  meta={meta}
  description="A marketing website and browser extension for a first-of-its-kind ad platform — designed to make an unfamiliar proposition feel simple, credible, and worth downloading."
  signoff="Designed at Gener8"
  signoffYear="2021"
>
  <Fragment slot="title">Gener<em>8</em></Fragment>

  <!-- Figure 01 — hero shot -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/gener8/image-gener8-1-m.jpg" />
      <img src="/images/projects/gener8/image-gener8-1.jpg" alt="Gener8 marketing site hero" loading="eager" />
    </picture>
  </figure>

  <!-- Chapter I — Challenge -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num">I.</span>
      <span class="chapter__label b2">The challenge</span>
    </header>

    <blockquote class="chapter__quote">
      A genuinely novel product entering a crowded and sceptical market —
      where the design challenge was as much about trust and clarity as it
      was about aesthetics.
    </blockquote>

    <div class="chapter__body">
      <p class="b1">
        Gener8 is a browser extension that flips the advertising model on its
        head. Instead of passively serving ads to users, it lets them opt in,
        profit from the ads they see, and take back control of their data.
      </p>
    </div>
  </section>

  <!-- Figure 02 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/gener8/image-gener8-2-m.jpg" />
      <img src="/images/projects/gener8/image-gener8-2.jpg" alt="Gener8 marketing site sections" loading="lazy" />
    </picture>
  </figure>

  <!-- Chapter II — Process -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num">II.</span>
      <span class="chapter__label b2">The process</span>
    </header>

    <h2 class="chapter__h2">
      One designer, one CEO, <em>three months.</em>
    </h2>

    <div class="chapter__body chapter__body--double">
      <p class="b1">
        Working directly with the CEO, I was brought in as the sole designer
        to deliver the full website and extension UI. The brief was clear:
        make a complex, unfamiliar proposition feel simple and credible,
        bring the product to the forefront, and build something that
        converted. Over three months we worked closely together — his
        product vision, my design execution — to produce a website built
        around a CRO strategy designed to turn curiosity into downloads.
      </p>
      <p class="b1">
        The design had to do a lot of work. The extension itself was a new
        category of product, so the website needed to explain what Gener8
        was, why it was different, and why users could trust it — all without
        overwhelming them. Simplicity and clarity drove every decision, from
        the information hierarchy down to the interaction details of the
        extension UI.
      </p>
    </div>
  </section>

  <!-- Figure 03 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/gener8/image-gener8-3-m.jpg" />
      <img src="/images/projects/gener8/image-gener8-3.jpg" alt="Extension UI details" loading="lazy" />
    </picture>
  </figure>

  <!-- Chapter III — Outcome -->
  <section class="chapter" data-reveal>
    <header class="chapter__head">
      <span class="chapter__num">III.</span>
      <span class="chapter__label b2">The outcome</span>
    </header>

    <blockquote class="chapter__quote">
      The site generated over 200,000 user downloads, and seven months after
      launch Gener8 secured investment on Dragons' Den. The product now has
      over 120,000 daily active users.
    </blockquote>

    <div class="stats">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat__value">{s.value}</span>
          <span class="stat__label b3">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Figure 04 -->
  <figure class="figure" data-reveal>
    <picture>
      <source media="(max-width: 768px)" srcset="/images/projects/gener8/image-gener8-4-m.jpg" />
      <img src="/images/projects/gener8/image-gener8-4.jpg" alt="Gener8 product screens" loading="lazy" />
    </picture>
  </figure>

  <!-- Figure 05 — YouTube video -->
  <figure class="figure figure--video" data-reveal>
    <div class="video-frame">
      <iframe
        src="https://www.youtube-nocookie.com/embed/dfUfwg1pY2s?rel=0"
        title="Gener8 product video"
        frameborder="0"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </figure>
</CaseStudyLayout>

<style is:global>
  /* Video figure — same card-frame as images */
  .figure--video .video-frame {
    position: relative;
    background: var(--color-card-bg);
    border-radius: 24px;
    padding: 8px;
    aspect-ratio: 16 / 9;
  }
  .figure--video iframe {
    position: absolute;
    inset: 8px;
    width: calc(100% - 16px);
    height: calc(100% - 16px);
    border: 0;
    border-radius: 18px;
  }
</style>
